---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { GAME } from '../../data/constants';

const title = 'Turbo Dismount 2 News — Updates, Patch Notes & Roadmap';
const description = 'Latest Turbo Dismount 2 news, patch notes, and development roadmap. Track updates from Secret Exit. Full release March 2026.';

const timeline = [
  {
    date: 'August 2024',
    version: '',
    title: 'Game Announced',
    desc: 'Secret Exit officially announced Turbo Dismount 2 as the sequel to the original Turbo Dismount (2014), with over 8 years of development.',
    type: 'announce',
  },
  {
    date: 'January 23, 2025',
    version: 'Early Access',
    title: 'Early Access Launch on Steam',
    desc: 'Turbo Dismount 2 entered Steam Early Access. First-person manual driving, advanced destruction physics, and Steam Workshop support available from day one.',
    type: 'release',
  },
  {
    date: 'January 31, 2025',
    version: 'v0.2.37',
    title: 'First Update',
    desc: 'First post-launch Early Access update addressing initial player feedback on physics, collision, and UI elements.',
    type: 'update',
  },
  {
    date: 'February 19, 2025',
    version: 'v0.2.47',
    title: 'Continued Improvements',
    desc: 'Ongoing iteration with gameplay tweaks, bug fixes, and performance improvements based on community feedback.',
    type: 'update',
  },
  {
    date: 'March 28, 2025',
    version: 'Update #8',
    title: 'Mall Racer Returns',
    desc: 'Restored the Mall Racer game mode and overhauled the scoring system with new calculation methods. Source: store.steampowered.com/news/app/2280350/',
    type: 'update',
  },
  {
    date: 'June 20, 2025',
    version: 'Update #7',
    title: 'NPC Faces & New Levels',
    desc: 'Added NPC custom face support, new playable levels, and multiple UI fixes. Source: store.steampowered.com/news/app/2280350/',
    type: 'update',
  },
  {
    date: 'August 21, 2025',
    version: 'Update #14',
    title: 'Workshop Season',
    desc: 'Introduced Workshop Season system and quality-of-life improvements for level creators and players. Source: store.steampowered.com/news/app/2280350/',
    type: 'major',
  },
  {
    date: 'February 2026',
    version: 'The BIG Update',
    title: '"The BIG Update" — Major Feature Drop',
    desc: 'Introduced new game modes, a fully revamped item unlock system, and significant gameplay improvements. One of the largest single updates during Early Access.',
    type: 'major',
  },
  {
    date: 'Early March 2026',
    version: 'Open Beta',
    title: 'Open Beta — Pre-Release Testing',
    desc: 'Open Beta launched ahead of the Full Release, allowing all players to test the 1.0-ready build and report remaining issues.',
    type: 'update',
  },
  {
    date: 'March 13, 2026',
    version: 'v1.0',
    title: 'Full Release',
    desc: 'Turbo Dismount 2 officially launched out of Early Access. Originally planned for February 27, delayed to March 13 to resolve final quality issues. Launched with 96% positive reviews on Steam.',
    type: 'release',
    highlight: true,
  },
];

const roadmapItems = [
  {
    phase: 'Short Term',
    timeframe: '3–6 months post-release',
    color: '#22C55E',
    items: [
      'Bug fixes and stability improvements',
      'Physics and collision refinements (Euphoria system)',
      'New content teased: "Protein Torpedo", "Murder Moon", "Quad-Fin Fighter" (source: @secretexit sneak peek)',
      'Additional classic levels',
      'Controller input optimization',
      'UI and menu polish',
    ],
  },
  {
    phase: 'Medium Term',
    timeframe: '6–12 months',
    color: '#0080F5',
    items: [
      'Mobile release — iOS (App Store)',
      'Mobile release — Android (Google Play)',
      'macOS support',
      'AI Racers (confirmed high-priority)',
      'Rollerskis vehicle — confirmed WIP (source: @secretexit tweet, March 2026)',
      'More game mode variety',
    ],
  },
  {
    phase: 'Long Term',
    timeframe: '12+ months',
    color: '#F57200',
    items: [
      'Workshop ecosystem expansion',
      'vs. multiplayer mode (concept phase)',
      'Additional level types and environments',
      'Community-requested features',
      'Console support — not currently planned',
    ],
  },
];

const v1Features = [
  'Racing mode with competitive lap-based gameplay',
  'Physics puzzle levels with structured objectives',
  'Obstacle course stages (Escape the Police, Time Trials)',
  'Chill Mode — free-form sandbox exploration',
  'Item unlock system introduced in The BIG Update',
  'Live webcam face tracking support',
  'Enhanced replay system with new recording options',
  'Steam Workshop with full developer toolset access',
  'Steam Deck verified',
  '30+ languages supported',
];

/** Convert human-readable date strings to ISO datetime values for <time>. */
const dateToIso = (d: string): string => {
  const months: Record<string, string> = {
    January: '01', February: '02', March: '03', April: '04',
    May: '05', June: '06', July: '07', August: '08',
    September: '09', October: '10', November: '11', December: '12',
  };
  // "March 13, 2026"
  const full = d.match(/^(\w+)\s+(\d{1,2}),\s*(\d{4})$/);
  if (full) return `${full[3]}-${months[full[1]]}-${full[2].padStart(2, '0')}`;
  // "February 2026"
  const monthYear = d.match(/^(\w+)\s+(\d{4})$/);
  if (monthYear) return `${monthYear[2]}-${months[monthYear[1]]}`;
  // "Early March 2026" — approximate to month
  const prefixed = d.match(/^\w+\s+(\w+)\s+(\d{4})$/);
  if (prefixed && months[prefixed[1]]) return `${prefixed[2]}-${months[prefixed[1]]}`;
  return '';
};

const typeColor: Record<string, string> = {
  announce: '#EAB308',
  release: '#22C55E',
  update: '#0080F5',
  major: '#F57200',
};

const typeLabel: Record<string, string> = {
  announce: 'Announced',
  release: 'Release',
  update: 'Update',
  major: 'Major Update',
};
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative overflow-hidden py-16 md:py-24">
    <img
      src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/page_bg_raw.jpg?t=1773497496"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-10"
      loading="eager"
      aria-hidden="true"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A0A00 0%, #2D1200 40%, #0D0D0F 100%);"></div>
    <div class="absolute top-1/2 left-1/4 w-[600px] h-[300px] -translate-y-1/2 opacity-15" style="background: radial-gradient(ellipse, rgba(245,114,0,0.4) 0%, transparent 70%);"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-[#8888A0]" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-[#FF8C12] transition-colors">Home</a></li>
          <li><span class="text-[#2A2A33]">/</span></li>
          <li class="text-[#B0B0BE]">News & Updates</li>
        </ol>
      </nav>

      <div class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(34,197,94,0.3)] bg-[rgba(34,197,94,0.08)] text-[#22C55E]">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E] animate-pulse"></span>
        v1.0 Full Release — <time datetime="2026-03-13">March 13, 2026</time>
      </div>

      <h1 class="font-[Orbitron] font-black text-3xl md:text-5xl uppercase tracking-wider leading-tight mb-4">
        <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
          Turbo Dismount 2
        </span>
        <br />
        <span class="text-[#F0F0F2] text-xl md:text-3xl">News & Updates</span>
      </h1>

      <p class="max-w-2xl text-[#B0B0BE] text-base md:text-lg leading-relaxed">
        Track every patch, major update, and roadmap milestone for Turbo Dismount 2.
        All data sourced from official Secret Exit announcements and Steam community posts.
      </p>
    </div>
  </section>

  <!-- Latest: v1.0 Highlight Card -->
  <section class="py-10 border-t border-[#2A2A33]">
    <div class="container">
      <div class="relative overflow-hidden rounded-2xl p-6 md:p-8" style="background: linear-gradient(135deg, rgba(245,114,0,0.12) 0%, rgba(34,197,94,0.06) 100%); border: 1px solid rgba(245,114,0,0.25);">
        <div class="absolute top-0 right-0 w-64 h-64 opacity-10" style="background: radial-gradient(circle, rgba(245,114,0,0.5) 0%, transparent 70%);"></div>
        <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-6">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="px-2.5 py-0.5 text-xs font-bold rounded bg-[#22C55E] text-white uppercase tracking-wider">Latest</span>
              <span class="px-2.5 py-0.5 text-xs font-semibold rounded-full border border-[rgba(245,114,0,0.4)] text-[#FF8C12]">v1.0 Full Release</span>
            </div>
            <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider text-[#F0F0F2] mb-2">
              Turbo Dismount 2 — Full Release
            </h2>
            <p class="text-[#B0B0BE] text-sm leading-relaxed max-w-xl">
              After 14 months in Early Access and 8+ years of total development, Turbo Dismount 2 launched out of Early Access on
              <strong class="text-[#F0F0F2]"><time datetime="2026-03-13">March 13, 2026</time></strong>. The game shipped with a 96% positive rating on Steam from 542 reviews.
              The original launch window was February 27 — delayed by two weeks to resolve final complexity issues.
            </p>
          </div>
          <div class="shrink-0 text-center">
            <div class="font-[Orbitron] font-black text-5xl text-[#F57200]">96%</div>
            <div class="text-xs text-[#8888A0] uppercase tracking-wider mt-1">Steam Positive</div>
            <div class="text-xs text-[#8888A0] mt-0.5">542 reviews</div>
            <a
              href={GAME.steamUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-4 px-5 py-2 text-sm font-bold text-white rounded-lg transition-all hover:-translate-y-0.5"
              style="background: linear-gradient(135deg, #FF8C12 0%, #F57200 100%); box-shadow: 0 4px 16px rgba(245,114,0,0.35);"
            >
              View on Steam
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Update Timeline -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
        Update Timeline
      </h2>
      <p class="text-[#B0B0BE] mb-10 max-w-xl">
        Every major milestone from announcement to Full Release, based on official Steam posts and developer announcements.
      </p>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-5 md:left-8 top-0 bottom-0 w-px bg-[#2A2A33]"></div>

        <div class="space-y-6">
          {timeline.map((item) => (
            <div class={`relative flex gap-4 md:gap-8 pl-14 md:pl-20 ${item.highlight ? 'ring-1 ring-[rgba(245,114,0,0.2)] rounded-xl p-4 -ml-4 bg-[rgba(245,114,0,0.04)]' : ''}`}>
              <!-- Dot -->
              <div
                class="absolute left-3 md:left-5 top-4 w-5 h-5 rounded-full border-2 border-[#0D0D0F] flex items-center justify-center shrink-0"
                style={`background-color: ${typeColor[item.type]}; box-shadow: 0 0 8px ${typeColor[item.type]}55;`}
              >
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <span class="text-xs font-semibold text-[#8888A0]">{dateToIso(item.date) ? <time datetime={dateToIso(item.date)}>{item.date}</time> : item.date}</span>
                  {item.version && (
                    <span
                      class="px-2 py-0.5 text-xs font-bold rounded"
                      style={`background-color: ${typeColor[item.type]}22; color: ${typeColor[item.type]}; border: 1px solid ${typeColor[item.type]}44;`}
                    >
                      {item.version}
                    </span>
                  )}
                  <span
                    class="px-2 py-0.5 text-xs rounded-full"
                    style={`color: ${typeColor[item.type]}; background: ${typeColor[item.type]}15;`}
                  >
                    {typeLabel[item.type]}
                  </span>
                </div>
                <h3 class="font-semibold text-[#F0F0F2] mb-1">{item.title}</h3>
                <p class="text-sm text-[#B0B0BE] leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What's New in v1.0 -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
          What's New in v1.0
        </h2>
        <p class="text-[#B0B0BE] mb-8">
          The Full Release includes all features developed across 14 months of Early Access, plus final content added in The BIG Update and Open Beta phase.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {v1Features.map((feature) => (
            <div class="flex items-start gap-3 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
              <svg class="w-4 h-4 text-[#22C55E] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
              <span class="text-sm text-[#B0B0BE]">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Development Roadmap -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
        Development Roadmap
      </h2>
      <p class="text-[#B0B0BE] mb-10 max-w-xl">
        Secret Exit has stated that v1.0 is a milestone, not an endpoint. These are the confirmed and expected priorities post-Full Release.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {roadmapItems.map((phase) => (
          <div class="rounded-xl border border-[#2A2A33] bg-[#141417] overflow-hidden">
            <div class="px-5 py-4 border-b border-[#2A2A33]" style={`border-left: 3px solid ${phase.color};`}>
              <div class="text-xs font-semibold uppercase tracking-wider mb-0.5" style={`color: ${phase.color};`}>
                {phase.phase}
              </div>
              <div class="text-[#8888A0] text-xs">{phase.timeframe}</div>
            </div>
            <ul class="p-5 space-y-3">
              {phase.items.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-[#B0B0BE]">
                  <span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full" style={`background-color: ${phase.color};`}></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-6 p-4 rounded-xl border border-[#2A2A33] bg-[#141417] text-sm text-[#8888A0]">
        <strong class="text-[#B0B0BE]">Note:</strong> Roadmap items reflect confirmed developer statements from Steam community posts and official announcements as of March 2026. Console support (PS5/Xbox/Switch) has not been confirmed or announced.
      </div>
    </div>
  </section>

  <!-- Community Reception (data from research report 03) -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-6">
          Community Reception
        </h2>
        <div class="flex flex-col md:flex-row gap-6 mb-6">
          <div class="space-y-4 text-[#B0B0BE] leading-relaxed flex-1">
          <p>
            Turbo Dismount 2's Full Release has been met with overwhelmingly positive feedback.
            On Steam, the game holds a <strong class="text-[#F57200]">96% positive rating</strong> from 542 reviews —
            surpassing the original's 93% from 4,240 reviews. The 30-day recent review score sits at 88% positive.
          </p>
          <p>
            Players consistently praise the <strong class="text-[#F0F0F2]">upgraded visual effects and music</strong>,
            the ability to load <strong class="text-[#F0F0F2]">multiple passengers</strong> into vehicles, and the
            <strong class="text-[#F0F0F2]">developer-grade Workshop tools</strong>. One Early Access reviewer summed it up:
            <em class="text-[#8888A0]">"This is an incredible feat, a massive step up from the first game, and overall just a great time."</em>
          </p>
          <p>
            Common community requests include <strong class="text-[#F0F0F2]">AI racers</strong> (confirmed as a developer priority),
            more classic levels, and improved Euphoria ragdoll physics. Camera lock issues and NPC traffic behavior are the most
            frequently reported bugs. Ready to try it?
            <a href="/download/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">Get TD2 on Steam</a> or
            <a href="/play-online/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">play the original free in your browser</a>.
          </p>
          </div>
          <div class="shrink-0 md:w-48">
            <img
              src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/header.jpg?t=1773497496"
              alt="Turbo Dismount 2 on Steam — 96% Overwhelmingly Positive"
              class="rounded-xl w-full object-cover border border-[#2A2A33]"
              loading="lazy"
              width="460"
              height="215"
            />
          </div>
        </div>

        <!-- Platform ratings -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-6">
          {[
            { platform: 'Steam (TD2)', score: '96%', reviews: '542 reviews' },
            { platform: 'Steam (Original)', score: '93%', reviews: '4,240 reviews' },
            { platform: 'App Store (Original)', score: '4.6/5', reviews: '10,744 ratings' },
            { platform: 'Google Play (Original)', score: '4.34/5', reviews: '600K+ ratings' },
          ].map((item) => (
            <div class="p-4 rounded-xl border border-[#2A2A33] bg-[#141417] text-center">
              <div class="font-[Orbitron] text-lg font-bold text-[#F57200]">{item.score}</div>
              <div class="text-xs text-[#8888A0] mt-1">{item.platform}</div>
              <div class="text-xs text-[#8888A0]">{item.reviews}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Known Issues (data from research report 03 — user reviews) -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-6">Known Issues (v1.0)</h2>
        <p class="text-sm text-[#B0B0BE] mb-6">Community-reported issues from Steam reviews and discussions. The developers are actively patching — check Steam News for the latest fixes.</p>
        <div class="space-y-3">
          {[
            { category: 'Camera', issue: 'Camera sometimes stutters and locks to an area outside the map. Reported on multiple levels.', status: 'Under investigation' },
            { category: 'Timer', issue: 'Timer occasionally starts too early, even while the ragdoll is still being crushed by a vehicle.', status: 'Under investigation' },
            { category: 'Traffic AI', issue: 'NPC traffic behavior is unstable — vehicles sometimes collide with each other and break the level design (e.g., T-Junction).', status: 'Under investigation' },
            { category: 'Windshield', issue: 'Windshield collision missing on certain vehicles (e.g., Bandit).', status: 'Reported' },
            { category: 'Ragdoll', issue: 'Ragdoll feet twitch during animation sequences. Ragdoll can clip into ground causing physics glitches.', status: 'Reported' },
            { category: 'Sprint End', issue: 'Sprint ends prematurely when vehicle gets stuck, even if ragdoll is still in motion. Players want a manual end-sprint option.', status: 'Feature request' },
          ].map((item) => (
            <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
              <span class="shrink-0 px-2 py-0.5 rounded text-xs font-semibold uppercase tracking-wider bg-[rgba(234,179,8,0.12)] text-[#EAB308] mt-0.5">{item.category}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-[#B0B0BE] leading-relaxed">{item.issue}</p>
                <p class="text-xs text-[#8888A0] mt-1">Status: {item.status}</p>
              </div>
            </div>
          ))}
        </div>
        <p class="text-xs text-[#8888A0] mt-4 italic">Source: Steam Community reviews and discussions (research report 03). Last verified: March 2026.</p>
      </div>
    </div>
  </section>

  <!-- Community Announcements -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
          Community Announcements
        </h2>
        <p class="text-[#B0B0BE] mb-8">
          Join the official Turbo Dismount 2 community and follow developer updates directly.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="https://store.steampowered.com/news/app/2280350/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start gap-4 p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200"
          >
            <div class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-[#1E1E24]">
              <svg class="w-5 h-5 text-[#F57200]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-4h2v2h-2v-2zm0-10h2v8h-2V6z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors text-sm">Steam News Hub</div>
              <div class="text-xs text-[#8888A0] mt-0.5">Official patch notes and dev updates</div>
            </div>
          </a>

          <a
            href="https://steamcommunity.com/app/2280350/discussions/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-start gap-4 p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200"
          >
