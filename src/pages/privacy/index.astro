---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Privacy Policy | Turbo Dismount 2';
const description = 'Privacy policy for turbodismount2.com — how we collect, use, and protect your data.';
---

<BaseLayout title={title} description={description} ogImage="/og-privacy.png">

  <section class="py-16 md:py-24">
    <div class="container">
      <nav class="mb-6 text-sm text-[#8888A0]" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-[#FF8C12] transition-colors">Home</a></li>
          <li><span class="text-[#2A2A33]">/</span></li>
          <li class="text-[#B0B0BE]">Privacy Policy</li>
        </ol>
      </nav>

      <h1 class="font-[Orbitron] font-black text-3xl md:text-4xl uppercase tracking-wider leading-tight mb-8">
        <span class="text-[#F0F0F2]">Privacy Policy</span>
      </h1>

      <div class="max-w-3xl space-y-8 text-[#B0B0BE] text-sm leading-relaxed">

        <p>
          Last updated: March 21, 2026
        </p>

        <p>
          turbodismount2.com is an unofficial fan site dedicated to Turbo Dismount 2. This privacy policy explains what data we collect and how it is used.
        </p>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Data Collection</h2>
          <p>
            We do not require user accounts, logins, or personal information to use this site. We do not collect names, email addresses, or any personally identifiable information directly.
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Analytics</h2>
          <p>
            We use <strong class="text-[#F0F0F2]">Google Analytics</strong> (GA4, property ID: G-CVNT0YNE9E) to understand how visitors use the site. Google Analytics collects anonymous usage data such as pages visited, time spent on pages, browser type, device type, and approximate geographic location. This data is aggregated and cannot be used to identify individual users.
          </p>
          <p class="mt-2">
            For more information, see <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-[#FF8C12] hover:text-[#FFAA44]">Google's Privacy Policy</a>.
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Cookies</h2>
          <p>
            This site uses cookies set by Google Analytics to distinguish unique visitors and track sessions. These are first-party cookies stored in your browser. You can disable cookies in your browser settings at any time.
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Third-Party Services</h2>
          <ul class="list-disc list-inside space-y-2 ml-2">
            <li><strong class="text-[#F0F0F2]">Google Analytics</strong> — anonymous site usage tracking as described above.</li>
            <li><strong class="text-[#F0F0F2]">CrazyGames</strong> — the Play Online page embeds a game iframe from crazygames.com. CrazyGames may set its own cookies and collect data according to its own <a href="https://www.crazygames.com/privacy-policy" target="_blank" rel="noopener noreferrer" class="text-[#FF8C12] hover:text-[#FFAA44]">privacy policy</a>.</li>
            <li><strong class="text-[#F0F0F2]">Steam (Valve)</strong> — we link to Steam store pages and community resources. Clicking these links takes you to steampowered.com, which is governed by <a href="https://store.steampowered.com/privacy_agreement/" target="_blank" rel="noopener noreferrer" class="text-[#FF8C12] hover:text-[#FFAA44]">Valve's privacy policy</a>.</li>
            <li><strong class="text-[#F0F0F2]">Fonts</strong> — web fonts (Orbitron & Inter) are self-hosted on our server. No requests are sent to Google or any third-party font service.</li>
          </ul>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Data Retention</h2>
          <p>
            We do not store any personal data on our servers. Analytics data is retained by Google according to their default retention settings (14 months).
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Children's Privacy</h2>
          <p>
            This site is not directed at children under 13. We do not knowingly collect personal information from children.
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Changes to This Policy</h2>
          <p>
            We may update this privacy policy from time to time. Changes will be posted on this page with an updated revision date.
          </p>
        </div>

        <div>
          <h2 class="font-[Orbitron] text-lg font-bold uppercase tracking-wider text-[#F0F0F2] mb-3">Contact</h2>
          <p>
            If you have questions about this privacy policy, please reach out via the site's contact channels or open an issue on our GitHub repository.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://turbodismount2.com/" },
      { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": "https://turbodismount2.com/privacy/" }
    ]
  })} />

</BaseLayout>
