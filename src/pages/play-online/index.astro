---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { GAME } from '../../data/constants';

const title = 'Play Turbo Dismount 2 Unblocked Online Free — Browser Game';
const description = 'Play Turbo Dismount unblocked in your browser for free. No download, works on school WiFi. Looking for Turbo Dismount 2? Get it on Steam for the full experience.';

const howToSteps = [
  {
    step: 1,
    title: 'Wait for the game to load',
    desc: 'The browser game loads directly below — no download, no install required.',
  },
  {
    step: 2,
    title: 'Pick your vehicle and stage',
    desc: 'Choose from available vehicles and select a stage to launch from.',
  },
  {
    step: 3,
    title: 'Set your launch angle and speed',
    desc: 'Use the green indicator to adjust the power and angle before launching.',
  },
  {
    step: 4,
    title: 'Launch and watch the chaos',
    desc: 'Hit the launch button and watch the physics-based destruction unfold.',
  },
  {
    step: 5,
    title: 'Beat your high score',
    desc: 'Try different vehicles and positions to maximize your damage score.',
  },
];

const faqs = [
  {
    q: 'Can I play Turbo Dismount 2 online?',
    a: 'Turbo Dismount 2 is a Steam-exclusive PC download — it cannot be played in a browser. What you can play online is the original Turbo Dismounting, a browser-based version of the classic game embedded on this page.',
  },
  {
    q: 'Is this game unblocked? Does it work on school WiFi?',
    a: 'Yes. The game runs via CrazyGames which works in most school and office browsers. No plugins required, just a modern browser with JavaScript enabled.',
  },
  {
    q: 'Is the browser version free to play?',
    a: `The browser version embedded here is completely free. Turbo Dismount 2 (the full sequel on Steam) costs ${GAME.price}, currently discounted ${GAME.discountPercent}% to ${GAME.salePrice} during the launch period.`,
  },
  {
    q: 'Does this work on mobile phones?',
    a: 'The browser version has partial mobile support — it works on some Android and iOS browsers, but touch controls are limited. For the best experience, use a desktop or laptop.',
  },
  {
    q: "What is the difference between this and Turbo Dismount 2?",
    a: 'The browser version is the original Turbo Dismounting — a simplified, older edition. Turbo Dismount 2 (Steam) adds fully manual vehicle controls, first-person driving, advanced destruction physics powered by Unity 6.3, Steam Workshop with developer-grade modding tools, live webcam face tracking, and much more.',
  },
];

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Play Turbo Dismount Online Free",
  "description": "Play Turbo Dismounting in your browser — no download needed.",
  "step": howToSteps.map((item) => ({
    "@type": "HowToStep",
    "name": item.title,
    "text": item.desc,
    "position": item.step,
  })),
};

const relatedGames = [
  {
    title: 'Happy Wheels',
    desc: 'Physics-based ragdoll obstacle course game — extremely popular browser classic.',
    url: 'https://www.totaljerkface.com/happy_wheels.tjf',
    tag: 'Browser Free',
  },
  {
    title: 'Stair Dismount',
    desc: 'The original dismount game from Secret Exit. Push people down stairs for maximum damage.',
    url: 'https://store.steampowered.com/app/220460/Stair_Dismount/',
    tag: 'Steam',
  },
  {
    title: 'Kill the Dummy',
    desc: 'Ragdoll physics destruction game. Attack a dummy with various weapons and tools.',
    url: 'https://www.crazygames.com/game/kill-the-dummy',
    tag: 'Browser Free',
  },
  {
    title: 'Car Crash Simulator',
    desc: 'Realistic soft-body car crash physics simulation with 60+ vehicles.',
    url: 'https://www.crazygames.com/game/car-crash-simulator-royale',
    tag: 'Browser Free',
  },
];
---

<BaseLayout title={title} description={description} canonicalUrl="https://turbodismount2.com/play-online/">

  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://turbodismount2.com/" },
      { "@type": "ListItem", "position": 2, "name": "Play Online", "item": "https://turbodismount2.com/play-online/" }
    ]
  })} />

  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a,
      },
    })),
  })} />

  <!-- HowTo Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A0A00 0%, #2D1200 40%, #0D0D0F 100%);"></div>
    <!-- Hero background image -->
    <img
      src="https://img.youtube.com/vi/_eY5eaJG-1s/maxresdefault.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-10"
      loading="eager"
      aria-hidden="true"
      width="1280"
      height="720"
    />

    <div class="absolute top-1/2 left-1/4 w-[600px] h-[300px] opacity-15" style="background: radial-gradient(ellipse, rgba(245,114,0,0.4) 0%, transparent 70%);"></div>
    <div class="absolute top-1/3 left-0 right-0 h-px opacity-25" style="background: linear-gradient(90deg, transparent 0%, rgba(245,114,0,0.6) 50%, transparent 100%); animation: speed-line 3s ease-in-out infinite;"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#8888A0] mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF8C12] transition-colors duration-200">Home</a>
        <span>/</span>
        <span class="text-[#B0B0BE]">Play Online</span>
      </nav>

      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-5 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(34,197,94,0.3)] bg-[rgba(34,197,94,0.08)] text-[#22C55E]">
          <span class="w-1.5 h-1.5 rounded-full bg-[#22C55E] animate-pulse"></span>
          Free to Play — No Download
        </div>

        <h1 class="font-[Orbitron] font-black text-3xl md:text-4xl lg:text-5xl uppercase tracking-wider leading-tight mb-4">
          <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
            Play Turbo Dismount 2
          </span>
          <br />
          <span class="text-[#F0F0F2] text-xl md:text-2xl lg:text-3xl tracking-wide">
            Unblocked Online Free
          </span>
        </h1>

        <p class="text-base md:text-lg text-[#B0B0BE] leading-relaxed mb-6 max-w-2xl">
          Play the original <strong class="text-[#F0F0F2]">Turbo Dismounting</strong> directly in your browser —
          no download, no install, no account needed. Works on school and office networks.
        </p>

        <!-- Notice: This is not TD2 -->
        <div class="flex items-start gap-3 p-4 rounded-xl border border-[rgba(234,179,8,0.3)] bg-[rgba(234,179,8,0.06)] max-w-2xl">
          <svg class="w-5 h-5 text-[#EAB308] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
          </svg>
          <p class="text-sm text-[#B0B0BE]">
            <strong class="text-[#EAB308]">Note:</strong> This is the original browser-based Turbo Dismounting — not Turbo Dismount 2.
            TD2 is available exclusively on Steam and requires a download.
            <a href="/download/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium ml-1">Get TD2 on Steam &rarr;</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Game Embed Section -->
  <section class="py-8 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <!-- Game Frame -->
        <div class="relative rounded-2xl overflow-hidden border border-[#2A2A33] bg-[#141417]" style="box-shadow: 0 8px 40px rgba(0,0,0,0.6);">
          <!-- Header bar -->
          <div class="flex items-center justify-between px-4 py-3 border-b border-[#2A2A33] bg-[#0D0D0F]">
            <div class="flex items-center gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-[#E01C1C]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#EAB308]"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-[#22C55E]"></div>
              <span class="ml-3 text-xs text-[#8888A0] font-mono">turbo-dismounting — browser game</span>
            </div>
            <span class="text-xs text-[#8888A0]">via CrazyGames</span>
          </div>

          <!-- Loading placeholder + iframe -->
          <div class="relative" style="aspect-ratio: 16/9; min-height: 360px;">
            <!-- Loading state -->
            <div id="game-loading" class="absolute inset-0 flex flex-col items-center justify-center z-10 bg-[#141417]">
              <div class="w-12 h-12 rounded-full border-2 border-[#2A2A33] border-t-[#F57200] animate-spin mb-4"></div>
              <p class="text-sm text-[#8888A0]">Loading game...</p>
            </div>
            <!-- Game iframe -->
            <iframe
              id="game-iframe"
              src="https://www.crazygames.com/embed/turbo-dismounting"
              title="Turbo Dismounting — Play Free Online"
              allow="autoplay; fullscreen *"
              sandbox="allow-scripts allow-same-origin allow-popups allow-fullscreen"
              scrolling="no"
              allowfullscreen
              loading="lazy"
              class="absolute inset-0 w-full h-full border-0"
            ></iframe>
          </div>
        </div>

        <!-- Below game info -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-4 px-1">
          <p class="text-xs text-[#8888A0]">
            Game hosted by CrazyGames. Click inside the game area to start playing.
          </p>
          <a
            href="/download/"
            class="text-xs font-semibold text-[#FF8C12] hover:text-[#FFAA44] transition-colors duration-200 whitespace-nowrap"
          >
            Want the full game? Get Turbo Dismount 2 on Steam &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TD2 Upsell Section -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div class="relative overflow-hidden rounded-2xl p-8 md:p-10" style="background: linear-gradient(135deg, rgba(245,114,0,0.12) 0%, rgba(0,128,245,0.08) 100%); border: 1px solid rgba(245,114,0,0.25);">
          <!-- Decorative glow -->
          <div class="absolute top-0 right-0 w-64 h-64 opacity-10" style="background: radial-gradient(circle, rgba(245,114,0,0.5) 0%, transparent 70%);"></div>

          <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 mb-4 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(245,114,0,0.3)] bg-[rgba(245,114,0,0.08)] text-[#FF8C12]">
                New Release — <time datetime="2026-03">March 2026</time>
              </div>
              <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
                Looking for<br />Turbo Dismount 2?
              </h2>
              <p class="text-[#B0B0BE] text-sm leading-relaxed mb-6">
                The full sequel is here. Turbo Dismount 2 brings first-person manual driving,
                advanced destruction physics on Unity 6.3, Steam Workshop with dev-grade modding tools,
                live webcam face tracking, and 96% positive reviews on Steam.
              </p>
              <div class="flex flex-col sm:flex-row items-start gap-3">
                <a
                  href={GAME.steamUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 text-sm font-bold text-white rounded-xl transition-all duration-300 hover:-translate-y-0.5"
                  style="background: linear-gradient(135deg, #FF8C12 0%, #F57200 50%, #C95A00 100%); box-shadow: 0 4px 20px rgba(245,114,0,0.35);"
                >
                  Buy on Steam — {GAME.price}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
                <a
                  href="/download/"
                  class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-[#F0F0F2] rounded-xl border border-[#2A2A33] hover:border-[rgba(245,114,0,0.4)] bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300"
                >
                  Download Guide
                </a>
              </div>
              <p class="text-xs text-[#8888A0] mt-3">{GAME.discountPercent}% launch discount — limited time</p>
            </div>

            <!-- TD2 feature comparison -->
            <div class="space-y-2.5">
              <!-- Steam capsule image -->
              <img
                src="https://cdn.cloudflare.steamstatic.com/steam/apps/2280350/capsule_616x353.jpg"
                alt="Turbo Dismount 2 — available on Steam"
                class="rounded-xl border border-[#2A2A33] w-full mb-4"
                loading="lazy"
                width="616"
                height="353"
              />
              <p class="text-xs text-[#8888A0] uppercase tracking-wider font-semibold mb-3">TD2 vs Browser Version</p>
              {[
                { label: 'First-person manual driving', browser: false, td2: true },
                { label: 'Advanced destruction physics', browser: false, td2: true },
                { label: 'Steam Workshop (mod tools)', browser: false, td2: true },
                { label: 'Live webcam face tracking', browser: false, td2: true },
                { label: 'Enhanced replay system', browser: false, td2: true },
                { label: 'Free to play', browser: true, td2: false },
                { label: 'No download required', browser: true, td2: false },
                { label: 'Works in browser', browser: true, td2: false },
              ].map((row) => (
                <div class="flex items-center gap-3 text-sm">
                  <span class="flex-1 text-[#B0B0BE]">{row.label}</span>
                  <div class="flex items-center gap-1 w-16 justify-center">
                    {row.browser ? (
                      <svg class="w-4 h-4 text-[#22C55E]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-[#8888A0]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/>
                      </svg>
                    )}
                    <span class="text-[10px] text-[#8888A0]">Browser</span>
                  </div>
                  <div class="flex items-center gap-1 w-12 justify-center">
                    {row.td2 ? (
                      <svg class="w-4 h-4 text-[#F57200]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-[#8888A0]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/>
                      </svg>
                    )}
                    <span class="text-[10px] text-[#FF8C12]">TD2</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About This Version (data from research report 01) -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-6">About This Browser Version</h2>
        <div class="space-y-4 text-sm text-[#B0B0BE] leading-relaxed">
          <p>
            The game embedded above is <strong class="text-[#F0F0F2]">Turbo Dismounting</strong> — a simplified browser adaptation
            of the original 2014 Turbo Dismount by Secret Exit Ltd. It runs directly in your browser via CrazyGames with no download required.
          </p>
          <p>
            The original Turbo Dismount launched on <strong class="text-[#F0F0F2]">Steam in May 2014</strong>,
            followed by iOS (September 2014) and Android (November 2014). It accumulated over
            <strong class="text-[#F57200]">71 million downloads</strong> across all platforms, driven partly by
            coverage from YouTubers like PewDiePie, Jacksepticeye, and Markiplier.
          </p>
          <p>
            <strong class="text-[#F0F0F2]">Turbo Dismount 2</strong> (the full sequel) launched on Steam on <time datetime="2026-03-13">March 13, 2026</time>
            after 8+ years of development. It features Unity 6.3 LTS, manual first-person driving, 6 game modes,
            and developer-grade <a href="/workshop/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">Workshop tools</a>.
            Check the <a href="/guides/how-to-play/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">How to Play guide</a>
            to learn what's new.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Play -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
          How to Play
        </h2>
        <p class="text-[#B0B0BE] text-sm mb-8">Get started with the browser version in 5 steps.</p>

        <div class="space-y-3">
          {howToSteps.map((item) => (
            <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
              <div class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center font-[Orbitron] font-bold text-sm text-[#F57200]" style="background: rgba(245,114,0,0.1); border: 1px solid rgba(245,114,0,0.2);">
                {item.step}
              </div>
              <div>
                <h3 class="text-[#F0F0F2] font-semibold mb-0.5">{item.title}</h3>
                <p class="text-sm text-[#8888A0] leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider text-center mb-10">
          Frequently Asked Questions
        </h2>

        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="group rounded-xl border border-[#2A2A33] bg-[#141417] overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-[#F0F0F2] font-medium hover:bg-[#1E1E24] transition-colors duration-200">
                <span>{faq.q}</span>
                <svg class="w-5 h-5 text-[#8888A0] shrink-0 ml-4 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm text-[#B0B0BE] leading-relaxed border-t border-[#1E1E24]">
                <p class="pt-4">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Related Games -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-2">
          Related Games
        </h2>
        <p class="text-[#B0B0BE] text-sm mb-8">More physics destruction games you might enjoy.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedGames.map((game) => (
            <a
              href={game.url}
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="group flex items-start gap-4 p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-300"
            >
              <div class="shrink-0 w-10 h-10 rounded-lg bg-[#1E1E24] flex items-center justify-center border border-[#2A2A33]">
                <svg class="w-5 h-5 text-[#8888A0] group-hover:text-[#F57200] transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5S14.67 12 15.5 12s1.5.67 1.5 1.5S16.33 15 15.5 15zm3-3c-.83 0-1.5-.67-1.5-1.5S17.67 10 18.5 10s1.5.67 1.5 1.5S19.33 12 18.5 12z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h3 class="text-sm font-semibold text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors duration-200">{game.title}</h3>
                  <span class="px-2 py-0.5 text-[10px] font-semibold rounded-full border border-[#2A2A33] text-[#8888A0] shrink-0">{game.tag}</span>
                </div>
                <p class="text-xs text-[#8888A0] leading-relaxed">{game.desc}</p>
              </div>
              <svg class="w-4 h-4 text-[#2A2A33] group-hover:text-[#F57200] transition-colors duration-200 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
          Ready for the Full Experience?
        </h2>
        <p class="text-[#B0B0BE] text-sm mb-6 max-w-md mx-auto">
          The browser version is fun — but Turbo Dismount 2 on Steam takes it to another level
          with physics, modding, and manual driving that the original never had.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href={GAME.steamUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-bold text-white rounded-xl transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #FF8C12 0%, #F57200 50%, #C95A00 100%); box-shadow: 0 4px 20px rgba(245,114,0,0.35);"
          >
            Get Turbo Dismount 2 — {GAME.price}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a
            href="/download/"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-[#F0F0F2] rounded-xl border border-[#2A2A33] hover:border-[rgba(245,114,0,0.4)] bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300"
          >
            System Requirements
          </a>
        </div>
        <p class="text-xs text-[#8888A0] mt-3">{GAME.discountPercent}% launch discount — {GAME.salePrice} for a limited time</p>
      </div>
    </div>
  </section>

<script>
  // T01: Hide loading spinner when iframe finishes loading.
  // sandbox attribute blocks inline onload, so we use addEventListener here instead.
  document.getElementById('game-iframe')?.addEventListener('load', () => {
    const loading = document.getElementById('game-loading');
    if (loading) loading.classList.add('hidden');
  });

  // Fallback: auto-hide after 8 seconds in case the load event is delayed.
  setTimeout(() => {
    const loading = document.getElementById('game-loading');
    if (loading && !loading.classList.contains('hidden')) {
      loading.classList.add('hidden');
    }
  }, 8000);
</script>

</BaseLayout>
