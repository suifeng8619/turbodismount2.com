---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GAME } from '../data/constants';

const title = 'Turbo Dismount 2 Wiki, Guides & Vehicle Database';
const description = 'Complete Turbo Dismount 2 resource — guides, vehicle database, level walkthroughs, Workshop creations, tips & tricks. Updated March 2026.';

const features = [
  {
    title: 'Guides & Tips',
    desc: 'Master the physics, score higher, and unlock achievements',
    href: '/guides/how-to-play/',
    svgPath: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
    color: '#F57200',
  },
  {
    title: 'Vehicle Database',
    desc: 'All vehicles with stats, speed, handling & durability ratings',
    href: '/database/vehicles/',
    svgPath: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10h10zm0 0h6a1 1 0 001-1v-5a1 1 0 00-.293-.707l-3-3A1 1 0 0016 6h-3v10z',
    color: '#0080F5',
  },
  {
    title: 'Level Guide',
    desc: 'Every level walkthrough with high score strategies',
    href: '/database/levels/',
    svgPath: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
    color: '#22C55E',
  },
  {
    title: 'Workshop',
    desc: 'Best community creations — maps, modes, mods & tools',
    href: '/workshop/',
    svgPath: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    color: '#EAB308',
  },
  {
    title: 'Play Online',
    desc: 'Play Turbo Dismount in your browser — no download needed',
    href: '/play-online/',
    svgPath: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    color: '#E01C1C',
  },
  {
    title: 'Download',
    desc: 'Get Turbo Dismount 2 on Steam — $19.99 (30% off now)',
    href: '/download/',
    svgPath: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4',
    color: '#A855F7',
  },
];

const quickFaqs = [
  { q: 'Is Turbo Dismount 2 free?', a: 'Turbo Dismount 2 costs $19.99 on Steam (currently 30% off at $13.99). The original Turbo Dismount is free on mobile.' },
  { q: 'Can I play Turbo Dismount 2 on mobile?', a: 'Not yet. The mobile version (iOS/Android) is planned for release after the PC launch. Currently only available on Steam (PC/Linux).' },
  { q: 'Does Turbo Dismount 2 support mods?', a: 'Yes! Steam Workshop support lets you create and share custom levels, game modes, obstacles, traps, and power-ups using the same tools the developers use.' },
  { q: 'What are the system requirements?', a: 'Minimum: Intel Core 2 Duo, 16GB RAM, DirectX 11 GPU, 4GB storage. The game is only 1.05GB and runs on most modern PCs.' },
];

const stats = [
  { value: '96%', label: 'Steam Positive Reviews' },
  { value: '70M+', label: 'Series Downloads' },
  { value: '30+', label: 'Languages Supported' },
  { value: '8 Years', label: 'In Development' },
];
---

<BaseLayout title={title} description={description} isHome={true}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 md:py-28 lg:py-36">
    <!-- Background gradient -->
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A0A00 0%, #2D1200 30%, #0D1A2E 70%, #080D18 100%);"></div>

    <!-- Decorative glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] opacity-20" style="background: radial-gradient(ellipse, rgba(245,114,0,0.3) 0%, transparent 70%);"></div>

    <!-- Hero background image -->
    <img
      src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/page_bg_raw.jpg?t=1773497496"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-35"
      loading="eager"
      aria-hidden="true"
      width="1920"
      height="1080"
    />

    <!-- Speed lines decoration -->
    <div class="absolute top-1/4 left-0 right-0 h-px opacity-30" style="background: linear-gradient(90deg, transparent 0%, rgba(245,114,0,0.6) 50%, transparent 100%); animation: speed-line 3s ease-in-out infinite;"></div>
    <div class="absolute top-2/3 left-0 right-0 h-px opacity-20" style="background: linear-gradient(90deg, transparent 0%, rgba(0,128,245,0.4) 50%, transparent 100%); animation: speed-line 4s ease-in-out infinite 1s;"></div>

    <div class="container relative z-10 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(245,114,0,0.3)] bg-[rgba(245,114,0,0.08)] text-[#FF8C12]">
        <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
        Full Release — <time datetime="2026-03">March 2026</time>
      </div>

      <!-- Title -->
      <h1 class="font-[Orbitron] font-black text-4xl md:text-5xl lg:text-7xl uppercase tracking-wider leading-tight mb-6">
        <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
          Turbo Dismount 2
        </span>
        <br />
        <span class="text-[#F0F0F2] text-2xl md:text-3xl lg:text-4xl tracking-wide">
          Wiki, Guides & Database
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="max-w-2xl mx-auto text-base md:text-lg text-[#B0B0BE] leading-relaxed mb-10">
        The ultimate resource for the comedy physics racing sandbox.
        Guides, vehicle stats, level walkthroughs, Workshop creations, and everything you need to master the art of destruction.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/guides/how-to-play/"
          class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-bold text-white rounded-xl transition-all duration-300 hover:-translate-y-0.5"
          style="background: linear-gradient(135deg, #FF8C12 0%, #F57200 50%, #C95A00 100%); box-shadow: 0 4px 24px rgba(245,114,0,0.4);"
        >
          Start Playing
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/play-online/"
          class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold text-[#F0F0F2] rounded-xl border border-[#2A2A33] hover:border-[rgba(245,114,0,0.4)] bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300"
        >
          <svg class="w-5 h-5 text-[#F57200]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
          Play Online Free
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y border-[#2A2A33] bg-[#141417]">
    <div class="container py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div>
            <div class="font-[Orbitron] font-bold text-2xl md:text-3xl text-[#F57200]">{stat.value}</div>
            <div class="text-xs text-[#8888A0] uppercase tracking-wider mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-12 md:py-16">
    <div class="container">
      <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider text-center mb-4">
        Turbo Dismount 2 Resources
      </h2>
      <p class="text-center text-[#B0B0BE] mb-12 max-w-xl mx-auto">
        Comprehensive resources to help you master Turbo Dismount 2
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {features.map((feature) => (
          <a
            href={feature.href}
            class="group relative p-6 rounded-xl border border-[#2A2A33] bg-[#141417] transition-all duration-300 hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] hover:-translate-y-1 hover:shadow-[0_4px_32px_rgba(245,114,0,0.1)]"
          >
            <div class="mb-3 w-10 h-10 rounded-lg flex items-center justify-center" style={`background: ${feature.color}15;`}>
              <svg class="w-5 h-5" style={`color: ${feature.color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={feature.svgPath} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-[#F0F0F2] mb-2 group-hover:text-[#FF8C12] transition-colors duration-200">
              {feature.title}
            </h3>
            <p class="text-sm text-[#8888A0] leading-relaxed">{feature.desc}</p>
            <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <svg class="w-5 h-5 text-[#F57200]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Official Trailer -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider text-center mb-8">
          Official Trailer
        </h2>
        <!-- Lite YouTube embed — loads iframe only on click -->
        <div class="relative rounded-xl overflow-hidden border border-[#2A2A33] bg-[#141417]" style="aspect-ratio: 16/9;">
          <iframe
            id="trailer-iframe"
            class="absolute inset-0 w-full h-full hidden"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
          <button
            id="trailer-play-btn"
            class="absolute inset-0 w-full h-full flex flex-col items-center justify-center cursor-pointer group z-10"
            style="background: linear-gradient(180deg, rgba(13,13,15,0.3) 0%, rgba(13,13,15,0.7) 100%);"
            aria-label="Play official Turbo Dismount 2 trailer"
          >
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110" style="background: rgba(245,114,0,0.9); box-shadow: 0 0 32px rgba(245,114,0,0.5);">
              <svg class="w-7 h-7 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <span class="mt-4 text-sm font-medium text-[#B0B0BE] group-hover:text-white transition-colors duration-200">Watch the Official Trailer</span>
          </button>
          <img
            src="https://img.youtube.com/vi/_eY5eaJG-1s/maxresdefault.jpg"
            alt="Turbo Dismount 2 Official Trailer Thumbnail"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            width="1280"
            height="720"
          />
        </div>
        <p class="text-center text-xs text-[#8888A0] mt-3">Source: Secret Exit Ltd — YouTube</p>
      </div>
    </div>
  </section>

  <!-- About the Game -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-6">
          What is Turbo Dismount 2?
        </h2>
        <div class="space-y-4 text-[#B0B0BE] leading-relaxed">
          <p>
            <strong class="text-[#F0F0F2]">Turbo Dismount 2</strong> is the official sequel to the wildly successful comedy physics game developed by
            <strong class="text-[#F0F0F2]">Secret Exit Ltd</strong> (Finland). After 8+ years of development, it launched on Steam on <time datetime="2026-03-13">March 13, 2026</time>
            with <strong class="text-[#F57200]">96% positive reviews</strong>.
          </p>
          <p>
            The game features <strong class="text-[#F0F0F2]">fully manual vehicle controls</strong>, an advanced destruction physics engine powered by
            Unity 6.3 LTS, and a powerful <strong class="text-[#F0F0F2]">Steam Workshop</strong> system that uses the same tools the developers use —
            letting players create custom levels, game modes, obstacles, traps, and even entirely new rule systems.
          </p>
          <p>
            With diverse level objectives including racing, physics puzzles, police chases, time trials, and sandbox exploration, TD2 is far more than
            just a crash simulator. Add in live webcam face tracking, an enhanced replay system, and a beloved cast led by
            <strong class="text-[#F0F0F2]">Mr. Dismount</strong>, and you have one of 2026's most entertaining physics sandboxes.
          </p>
        </div>

        <!-- Steam header image -->
        <img
          src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/header.jpg?t=1773497496"
          alt="Turbo Dismount 2 Steam header image showing gameplay"
          class="rounded-xl border border-[#2A2A33] w-full mt-6"
          loading="lazy"
          width="460"
          height="215"
        />

        <!-- Key Features -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-8">
          {[
            'First-person manual driving',
            'Live webcam face support',
            'Advanced destruction physics',
            'Steam Workshop with dev tools',
            'Multiple game modes',
            'Enhanced replay system',
            '30+ languages supported',
            'Steam Deck verified',
          ].map((feature) => (
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-[#22C55E] shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
              <span class="text-[#B0B0BE]">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Development History (data from research reports 01, 03, 09) -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-6">
          Turbo Dismount 2 Development History
        </h2>
        <div class="space-y-4 text-[#B0B0BE] leading-relaxed">
          <p>
            The original <strong class="text-[#F0F0F2]">Turbo Dismount</strong> launched on Steam in May 2014, followed by iOS (September 2014) and
            Android (November 2014). Built by <strong class="text-[#F0F0F2]">Secret Exit Ltd</strong>, a small Finnish studio founded in 2006 in Helsinki,
            it became a viral sensation — accumulating over <strong class="text-[#F57200]">71 million downloads</strong> across all platforms, with
            50 million+ on Android alone.
          </p>
          <p>
            The game's popularity was fueled by major YouTubers including <strong class="text-[#F0F0F2]">PewDiePie</strong>,
            <strong class="text-[#F0F0F2]">Jacksepticeye</strong>, and <strong class="text-[#F0F0F2]">Markiplier</strong> — who even created
            custom levels in the Steam Workshop. On TikTok, Turbo Dismount content has generated videos with
            <strong class="text-[#F57200]">19.2 million views</strong>.
          </p>
          <p>
            Development of Turbo Dismount 2 took <strong class="text-[#F0F0F2]">over 8 years</strong>. The game was
            <a href="/news/" class="text-[#FF8C12] hover:text-[#FFAA44]">announced in <time datetime="2024-08">August 2024</time></a>,
            entered <strong class="text-[#F0F0F2]">Early Access on <time datetime="2025-01-23">January 23, 2025</time></strong>, and after a 14-month
            testing period (including "The BIG Update" in February 2026 and an Open Beta in early March), reached
            <a href="/download/" class="text-[#FF8C12] hover:text-[#FFAA44]">Full Release on <time datetime="2026-03-13">March 13, 2026</time></a>.
            The release was delayed from the original February 27 target to ensure quality.
          </p>
        </div>

        <!-- Timeline -->
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[
            { year: '2014', event: 'Original TD launches on Steam' },
            { year: '2024', event: 'TD2 announced for Steam' },
            { year: '2025', event: 'Early Access begins' },
            { year: '2026', event: 'Full Release v1.0' },
          ].map((item) => (
            <div class="p-4 rounded-xl border border-[#2A2A33] bg-[#141417] text-center">
              <div class="font-[Orbitron] text-lg font-bold text-[#F57200]">{item.year}</div>
              <div class="text-xs text-[#8888A0] mt-1">{item.event}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Updates (quick summary pointing to /news/) -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider mb-6">Latest Updates</h2>
        <div class="space-y-3">
          <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
            <span class="shrink-0 px-2 py-0.5 rounded text-xs font-bold uppercase bg-[rgba(34,197,94,0.12)] text-[#22C55E]">v1.0</span>
            <div>
              <p class="text-sm font-medium text-[#F0F0F2]">Full Release — <time datetime="2026-03-13">March 13, 2026</time></p>
              <p class="text-xs text-[#8888A0] mt-1">Turbo Dismount 2 officially leaves Early Access with 96% positive reviews.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
            <span class="shrink-0 px-2 py-0.5 rounded text-xs font-bold uppercase bg-[rgba(245,114,0,0.12)] text-[#F57200]">WIP</span>
            <div>
              <p class="text-sm font-medium text-[#F0F0F2]">New Content in Development</p>
              <p class="text-xs text-[#8888A0] mt-1">Rollerskis vehicle, "Protein Torpedo", "Murder Moon", and "Quad-Fin Fighter" teased by developers.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
            <span class="shrink-0 px-2 py-0.5 rounded text-xs font-bold uppercase bg-[rgba(0,128,245,0.12)] text-[#0080F5]">Plan</span>
            <div>
              <p class="text-sm font-medium text-[#F0F0F2]">Roadmap Highlights</p>
              <p class="text-xs text-[#8888A0] mt-1">AI Racers (high priority), iOS/Android mobile version, Mac support, and more game modes planned.</p>
            </div>
          </div>
        </div>
        <div class="mt-4 text-center">
          <a href="/news/" class="text-sm text-[#FF8C12] hover:text-[#FFAA44] font-medium">View full update timeline and roadmap &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-2xl md:text-3xl font-bold uppercase tracking-wider text-center mb-10">
          Frequently Asked Questions
        </h2>

        <div class="space-y-3">
          {quickFaqs.map((faq, i) => (
            <details class="group rounded-xl border border-[#2A2A33] bg-[#141417] overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-[#F0F0F2] font-medium hover:bg-[#1E1E24] transition-colors duration-200">
                <span>{faq.q}</span>
                <svg class="w-5 h-5 text-[#8888A0] shrink-0 ml-4 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm text-[#B0B0BE] leading-relaxed border-t border-[#1E1E24]">
                <p class="pt-4">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>

        <div class="text-center mt-8">
          <a href="/faq/" class="text-sm text-[#FF8C12] hover:text-[#FFAA44] font-medium transition-colors duration-200">
            View all FAQ &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="relative overflow-hidden rounded-2xl p-8 md:p-12 text-center" style="background: linear-gradient(135deg, rgba(245,114,0,0.15) 0%, rgba(0,128,245,0.1) 100%); border: 1px solid rgba(245,114,0,0.2);">
        <!-- CTA background image -->
        <img
          src="https://cdn.fastly.steamstatic.com/steamcommunity/public/images/apps/2280350/790f9624ae5167e1d7a6791b9f9012ba04276a19.jpg"
          alt=""
          class="absolute inset-0 w-full h-full object-cover opacity-10 rounded-2xl"
          loading="lazy"
          aria-hidden="true"
          width="460"
          height="215"
        />
        <div class="relative z-10">
