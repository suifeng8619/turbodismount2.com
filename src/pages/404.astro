---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Turbo Dismount 2"
  description="The page you're looking for doesn't exist. Head back to the Turbo Dismount 2 wiki and guides."
  noIndex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center px-6">
    <div class="text-center max-w-lg mx-auto">
      <!-- Error code -->
      <div class="text-[#F57200] font-display font-black text-[120px] leading-none tracking-tighter select-none opacity-20 mb-4"
           style="font-family: var(--font-display);">
        404
      </div>

      <!-- Heading -->
      <h1 class="uppercase text-3xl md:text-4xl font-black tracking-widest text-[#F0F0F2] mb-4"
          style="font-family: var(--font-display);">
        Page Not Found
      </h1>

      <!-- Description -->
      <p class="text-[#B0B0BE] text-base mb-8 leading-relaxed">
        This page went off the road and crashed. It may have been removed, renamed, or never existed.
      </p>

      <!-- Back to home button -->
      <a
        href="/"
        class="inline-flex items-center gap-2 px-8 py-3 bg-[#F57200] hover:bg-[#FF8C12] text-white font-bold rounded-lg transition-colors duration-200 uppercase tracking-wider text-sm"
        style="font-family: var(--font-display);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Back to Home
      </a>

      <!-- Popular pages -->
      <div class="mt-12 pt-8 border-t border-[#2A2A33]">
        <p class="text-sm text-[#8888A0] mb-4">Or try one of these popular pages:</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/guides/how-to-play/" class="px-4 py-2 text-sm text-[#B0B0BE] border border-[#2A2A33] rounded-lg hover:border-[rgba(245,114,0,0.3)] hover:text-[#FF8C12] transition-all">How to Play</a>
          <a href="/database/vehicles/" class="px-4 py-2 text-sm text-[#B0B0BE] border border-[#2A2A33] rounded-lg hover:border-[rgba(245,114,0,0.3)] hover:text-[#FF8C12] transition-all">Vehicles</a>
          <a href="/download/" class="px-4 py-2 text-sm text-[#B0B0BE] border border-[#2A2A33] rounded-lg hover:border-[rgba(245,114,0,0.3)] hover:text-[#FF8C12] transition-all">Download</a>
          <a href="/faq/" class="px-4 py-2 text-sm text-[#B0B0BE] border border-[#2A2A33] rounded-lg hover:border-[rgba(245,114,0,0.3)] hover:text-[#FF8C12] transition-all">FAQ</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
