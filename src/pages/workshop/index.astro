---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Turbo Dismount 2 Workshop — Best Mods, Maps & Custom Levels';
const description = 'Browse the best Turbo Dismount 2 Workshop creations. Custom levels, game modes, obstacles, traps. Learn how to create your own using developer-grade tools.';

interface CreationType {
  title: string;
  description: string;
  color: string;
  examples: string[];
}

interface FeaturedCreation {
  name: string;
  creator: string;
  type: string;
  description: string;
  workshopUrl: string;
  highlight?: string;
}

interface KnownCreator {
  name: string;
  specialty: string;
  description: string;
  notable: string;
}

const creationTypes: CreationType[] = [
  {
    title: 'Custom Levels',
    description: 'Build entirely new maps with unique layouts, traffic patterns, elevation changes, and environment themes. The most popular Workshop category.',
    color: '#F57200',
    examples: ['Highway stages', 'Urban environments', 'Arena maps', 'Vertical drops'],
  },
  {
    title: 'New Game Modes',
    description: 'Define entirely new rules for how the game is played. Change win conditions, add time pressure, modify scoring systems, or create something never seen before.',
    color: '#0080F5',
    examples: ['Survival challenges', 'Score attack variants', 'Racing modes', 'Custom objectives'],
  },
  {
    title: 'Power-ups',
    description: 'Design new collectible power-ups that change vehicle behavior mid-run. Speed boosts, shields, gravity modifiers — limited only by your imagination.',
    color: '#22C55E',
    examples: ['Speed multipliers', 'Impact amplifiers', 'Bounce pads', 'Teleporters'],
  },
  {
    title: 'Obstacles & Traps',
    description: 'Create new environmental hazards and interactive objects that appear in levels. These can be shared separately and used in any compatible level.',
    color: '#EAB308',
    examples: ['Spinning barriers', 'Explosive crates', 'Moving platforms', 'Magnetic zones'],
  },
  {
    title: 'Custom Rules',
    description: 'The most advanced creation type — define new logic systems that change how physics, scoring, and interactions work at a fundamental level.',
    color: '#A855F7',
    examples: ['Altered gravity', 'Modified collision scoring', 'Special spawn rules', 'Chain reaction logic'],
  },
];

const featuredCreations: FeaturedCreation[] = [
  {
    name: "Codeman's Turbo Dismount Levels",
    creator: 'Codeman',
    type: 'Level Collection',
    description: 'One of the highly subscribed Workshop collections, featuring multiple polished levels with varied themes. Codeman has been an active creator since the original Turbo Dismount, bringing years of level design experience to TD2.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
    highlight: 'Most Subscribed',
  },
  {
    name: "Bokchoi's Turbo Dismount Maps",
    creator: 'Bokchoi',
    type: 'Map Collection',
    description: 'Known for well-crafted map layouts that maximize scoring potential. Bokchoi\'s maps are designed with physics knowledge — every obstacle placement is intentional and reward-oriented.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
    highlight: 'Top Rated',
  },
  {
    name: 'GreenLuigi19 Collections',
    creator: 'GreenLuigi19',
    type: 'Level Collection',
    description: 'A consistently updated collection of Turbo Dismount levels. GreenLuigi19 is known for maintaining and iterating on their levels post-release based on community feedback.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
    highlight: 'Actively Updated',
  },
  {
    name: 'Highway Patrol Recreate',
    creator: 'Community Creator',
    type: 'Police Chase Level',
    description: 'A detailed recreation of a high-speed police pursuit scenario. Features authentic patrol vehicle placement and road infrastructure that creates natural chokepoints.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
  },
  {
    name: 'Hyperspeed Highway',
    creator: 'Community Creator',
    type: 'Extreme Speed Level',
    description: 'An extreme challenge where all traffic operates at maximum velocity. Every collision becomes instantaneous and devastating — recommended only for experienced players.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
    highlight: 'Expert Only',
  },
  {
    name: 'Atrocious Alley',
    creator: 'Community Creator',
    type: 'Urban Obstacle Course',
    description: 'A dense urban alleyway packed with hand-placed obstacles, traps, and environmental hazards. Each run produces a different chain reaction thanks to the complex obstacle interactions.',
    workshopUrl: 'https://steamcommunity.com/workshop/browse/?appid=2280350',
  },
];

const knownCreators: KnownCreator[] = [
  {
    name: 'Codeman',
    specialty: 'Multi-Level Collections',
    description: 'Long-standing Turbo Dismount creator with work spanning both TD1 and TD2. Known for quantity and quality across varied level themes.',
    notable: "Codeman's Turbo Dismount Levels",
  },
  {
    name: 'Bokchoi',
    specialty: 'Physics-Optimized Maps',
    description: 'Map designer with a focus on maximizing physics-based scoring opportunities. Levels are well-documented and often include recommended vehicle selections.',
    notable: "Bokchoi's Turbo Dismount Maps",
  },
  {
    name: 'GreenLuigi19',
    specialty: 'Maintained Level Collections',
    description: 'Iterative creator who updates levels based on community feedback. Provides reliable, well-maintained content that stays relevant as the game updates.',
    notable: 'GreenLuigi19 Collections',
  },
  {
    name: 'JosephDeAutismo',
    specialty: 'YouTube-Tied Content',
    description: 'Creator with connections to YouTube content creation. Known for levels that feature well in video format, with good visual variety per run.',
    notable: 'Maps used in Episode 1 - The Destructive Menace',
  },
  {
    name: 'ShadowDeathBlade93',
    specialty: 'Community Contributions',
    description: 'Active community member with confirmed Workshop contributions. Specific level themes not yet fully documented — browse their Workshop page directly.',
    notable: 'Various Workshop Submissions',
  },
];

const steps = [
  {
    number: '01',
    title: 'Install the Workshop SDK',
    desc: 'In your Steam library, find "Turbo Dismount 2 Workshop Tools" and install it. This is the same toolset Secret Exit uses internally.',
  },
  {
    number: '02',
    title: 'Open the Level Editor',
    desc: 'Launch the editor from Steam. You\'ll have access to the full Unity-based environment with drag-and-drop asset placement.',
  },
  {
    number: '03',
    title: 'Build and Place Assets',
    desc: 'Add roads, vehicles, obstacles, power-ups, spawn points, and environmental props. The interface is WYSIWYG — what you see is what players experience.',
  },
  {
    number: '04',
    title: 'Set Rules and Objectives',
    desc: 'Define win conditions, scoring modifiers, game mode rules, and any custom behaviors. This is where you shape the player experience.',
  },
  {
    number: '05',
    title: 'Publish to Steam Workshop',
    desc: 'Add a title, short description, and a preview screenshot, then click Publish. Your creation uploads instantly and subscribers get it automatically.',
  },
];

const td1vsTd2 = [
  {
    aspect: 'Creation Tools',
    td1: 'Basic level editor with limited assets',
    td2: 'Full developer-grade Unity toolset — identical to what Secret Exit uses',
  },
  {
    aspect: 'Creation Types',
    td1: 'Primarily custom levels only',
    td2: 'Levels, game modes, custom rules, obstacles, power-ups, traps',
  },
  {
    aspect: 'Game Modes',
    td1: 'Not creatable via Workshop',
    td2: 'Fully customizable — define new win conditions and play rules',
  },
  {
    aspect: 'Scripting',
    td1: 'Limited scripting support',
    td2: 'Custom rule engine — create new logic systems from scratch',
  },
  {
    aspect: 'Graphics Quality',
    td1: 'Standard Unity graphics',
    td2: 'Unity 6.3 LTS with modern lighting and effects support',
  },
  {
    aspect: 'Community Age',
    td1: '13+ years, hundreds of creations',
    td2: 'Launched March 2026 — rapidly growing',
  },
];

const faqs = [
  {
    q: 'Do I need programming skills to create Workshop content?',
    a: 'For basic levels, no programming is required. The level editor uses a visual drag-and-drop interface. Advanced content like custom game modes and rule systems may benefit from familiarity with logic-based scripting, but dedicated tutorials and community help are available.',
  },
  {
    q: 'Is the Workshop free to use?',
    a: 'Yes. The Workshop SDK is free to install for anyone who owns Turbo Dismount 2 on Steam. Creating and publishing content is free. Subscribing to and playing Workshop content is also free.',
  },
  {
    q: 'How is TD2 Workshop different from TD1?',
    a: 'Turbo Dismount 2 opens the full developer toolset to Workshop creators — the same tools Secret Exit uses to build official content. TD1 had a more limited editor. TD2 creators can make custom game modes, rules systems, and entirely new play mechanics that were impossible in TD1.',
  },
  {
    q: 'Can Workshop content break my game?',
    a: 'Workshop content runs in a sandboxed environment. Individual Workshop items cannot modify your base game installation. If a specific Workshop item causes issues, simply unsubscribe and it will be removed on next launch.',
  },
  {
    q: 'How do I find the best Workshop content?',
    a: 'Browse the Steam Workshop page for Turbo Dismount 2 and sort by "Most Popular" or "Top Rated". The creators listed on this page (Codeman, Bokchoi, GreenLuigi19) are reliable starting points. Check the "New & Trending" filter for recently published content.',
  },
  {
    q: 'Can I make money from Workshop creations?',
    a: 'No. Turbo Dismount 2 Workshop does not support paid Workshop items. All creator content is free. This is consistent with Secret Exit\'s approach to keeping the community open and accessible.',
  },
];
---

<BaseLayout title={title} description={description}>
  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  })} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #0D1A0A 0%, #1A2D12 30%, #0D1525 70%, #080D18 100%);"></div>
    <div class="absolute top-1/3 right-0 w-[600px] h-[400px] opacity-10" style="background: radial-gradient(ellipse, rgba(34,197,94,0.4) 0%, transparent 70%);"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[300px] opacity-10" style="background: radial-gradient(ellipse, rgba(245,114,0,0.3) 0%, transparent 70%);"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#8888A0] mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF8C12] transition-colors">Home</a>
        <span>/</span>
        <span class="text-[#B0B0BE]">Workshop</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-5 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(34,197,94,0.3)] bg-[rgba(34,197,94,0.08)] text-[#22C55E]">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          Developer-Grade Creation Tools
        </div>

        <h1 class="font-[Orbitron] font-black text-3xl md:text-5xl uppercase tracking-wider leading-tight mb-5">
          <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
            Turbo Dismount 2
          </span>
          <br />
          <span class="text-[#F0F0F2]">Steam Workshop</span>
        </h1>

        <p class="text-base md:text-lg text-[#B0B0BE] leading-relaxed max-w-2xl mb-6">
          Create and share custom levels, game modes, obstacles, and entirely new rule systems.
          TD2 Workshop gives every player the <strong class="text-[#22C55E]">same tools Secret Exit uses internally</strong> —
          not a simplified editor, but the actual development toolkit.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://steamcommunity.com/workshop/browse/?appid=2280350"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-bold text-white rounded-xl transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%); box-shadow: 0 4px 20px rgba(34,197,94,0.3);"
          >
            Browse Workshop on Steam
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          <a
            href="#getting-started"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-[#F0F0F2] rounded-xl border border-[#2A2A33] hover:border-[rgba(34,197,94,0.4)] bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300"
          >
            Creation Guide
            <svg class="w-4 h-4 text-[#22C55E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What Can You Create? -->
  <section class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
      <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3 text-center">
        What Can You Create?
      </h2>
      <p class="text-center text-[#B0B0BE] mb-12 text-sm max-w-xl mx-auto">
        TD2 Workshop supports five distinct creation categories, each powered by the same developer tools used to build the base game.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {creationTypes.map((type) => (
          <div
            class="group p-6 rounded-xl border bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300 hover:-translate-y-1 hover:border-[rgba(245,114,0,0.3)]"
            style={`border-color: #2A2A33;`}
          >
            <!-- Color accent bar -->
            <div class="w-full h-1 rounded-full mb-5" style={`background: linear-gradient(90deg, ${type.color}, ${type.color}44);`}></div>

            <h3 class="font-[Orbitron] text-base font-bold uppercase tracking-wide mb-3" style={`color: ${type.color};`}>
              {type.title}
            </h3>

            <p class="text-sm text-[#B0B0BE] leading-relaxed mb-4">{type.description}</p>

            <div class="space-y-1.5">
              <p class="text-xs text-[#8888A0] uppercase tracking-wider mb-2">Examples</p>
              {type.examples.map((ex) => (
                <div class="flex items-center gap-2 text-xs text-[#B0B0BE]">
                  <span class="w-1 h-1 rounded-full shrink-0" style={`background: ${type.color};`}></span>
                  {ex}
                </div>
              ))}
            </div>
          </div>
        ))}

        <!-- The "All the above" summary card -->
        <div class="sm:col-span-2 lg:col-span-3 p-6 rounded-xl border border-dashed border-[#2A2A33] bg-[rgba(245,114,0,0.03)] text-center">
          <p class="text-sm text-[#8888A0] mb-2">Every creation type uses the same Unity-based tools that Secret Exit uses internally.</p>
          <p class="text-xs text-[#8888A0] italic">
            "All of our game levels are built with the same tools we give to Workshop creators." — Secret Exit Ltd
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Workshop Creations -->
  <section class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
      <div class="flex items-start justify-between flex-wrap gap-4 mb-3">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider flex items-center gap-3">
          <span class="w-1 h-7 rounded-full" style="background: #F57200;"></span>
          Featured Workshop Creations
        </h2>
        <a
          href="https://steamcommunity.com/workshop/browse/?appid=2280350"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-semibold rounded-lg border border-[#2A2A33] bg-[#141417] text-[#B0B0BE] hover:border-[rgba(245,114,0,0.3)] hover:text-[#FF8C12] transition-all duration-200"
        >
          View All on Steam
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
      <p class="text-sm text-[#8888A0] mb-10 ml-4">
        Notable Workshop creations from the TD community. All free to subscribe on Steam Workshop.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {featuredCreations.map((creation) => (
          <a
            href={creation.workshopUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative p-6 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-300 hover:-translate-y-1 block"
          >
            {creation.highlight && (
              <span class="absolute top-4 right-4 px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-wider" style="background: rgba(245,114,0,0.15); color: #F57200; border: 1px solid rgba(245,114,0,0.3);">
                {creation.highlight}
              </span>
            )}

            <div class="mb-4">
              <h3 class="font-bold text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors duration-200 pr-24 leading-snug">
                {creation.name}
              </h3>
              <div class="flex items-center gap-3 mt-1.5">
                <span class="text-xs text-[#8888A0]">by {creation.creator}</span>
                <span class="px-2 py-0.5 text-xs rounded-md bg-[#1E1E24] text-[#B0B0BE] border border-[#2A2A33]">{creation.type}</span>
              </div>
            </div>

            <p class="text-sm text-[#B0B0BE] leading-relaxed mb-4">{creation.description}</p>

            <div class="flex items-center gap-2 text-xs font-medium" style="color: #F57200;">
              View on Steam Workshop
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Getting Started -->
  <section id="getting-started" class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
          How to Get Started
        </h2>
        <p class="text-[#B0B0BE] mb-10 text-sm leading-relaxed">
          From zero to published Workshop creator in five steps. No game development experience required for basic levels.
        </p>

        <div class="space-y-4">
          {steps.map((step) => (
            <div class="group flex gap-5 p-6 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.2)] transition-colors duration-200">
              <div class="shrink-0">
                <div class="font-[Orbitron] text-2xl font-black text-[rgba(245,114,0,0.4)] group-hover:text-[#F57200]">
                  {step.number}
                </div>
              </div>
              <div>
                <p class="font-bold text-[#F0F0F2] mb-1.5 text-base">{step.title}</p>
                <p class="text-sm text-[#B0B0BE] leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-5 rounded-xl border border-[rgba(34,197,94,0.2)] bg-[rgba(34,197,94,0.05)]">
          <p class="text-sm font-semibold text-[#22C55E] mb-1">Key advantage</p>
          <p class="text-sm text-[#B0B0BE]">
            Unlike other games that provide a simplified "creator mode," Turbo Dismount 2 Workshop uses the actual development build pipeline.
            This means you can achieve the same visual quality and behavioral complexity as the official levels.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Known Creators -->
  <section class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
      <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
        Known Creators
      </h2>
      <p class="text-sm text-[#8888A0] mb-10">Active Workshop creators with confirmed published content.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {knownCreators.map((creator) => (
          <div class="p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.2)] transition-colors duration-200">
            <!-- Avatar placeholder -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center font-[Orbitron] font-bold text-lg text-white mb-4" style="background: linear-gradient(135deg, #F57200, #C95A00);">
              {creator.name.slice(0, 2).toUpperCase()}
            </div>

            <h3 class="font-bold text-[#F0F0F2] mb-0.5">{creator.name}</h3>
            <p class="text-xs text-[#F57200] uppercase tracking-wider mb-3">{creator.specialty}</p>
            <p class="text-sm text-[#B0B0BE] leading-relaxed mb-3">{creator.description}</p>
            <div class="pt-3 border-t border-[#2A2A33]">
              <p class="text-xs text-[#8888A0] uppercase tracking-wider mb-1">Notable Work</p>
              <p class="text-xs text-[#B0B0BE]">{creator.notable}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Workshop vs TD1 -->
  <section class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
          Workshop vs TD1
        </h2>
        <p class="text-sm text-[#8888A0] mb-8">How Turbo Dismount 2 Workshop compares to the first game's modding tools.</p>

        <div class="overflow-x-auto rounded-xl border border-[#2A2A33]">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[#2A2A33]" style="background: #141417;">
                <th class="text-left px-5 py-4 text-xs font-semibold text-[#8888A0] uppercase tracking-wider w-1/3">Feature</th>
                <th class="text-left px-5 py-4 text-xs font-semibold text-[#8888A0] uppercase tracking-wider w-1/3">
                  <span class="text-[#B0B0BE]">Turbo Dismount 1</span>
                </th>
                <th class="text-left px-5 py-4 text-xs font-semibold text-[#F57200] uppercase tracking-wider w-1/3">
                  Turbo Dismount 2
                </th>
              </tr>
            </thead>
            <tbody>
              {td1vsTd2.map((row, i) => (
                <tr class={`border-b border-[#1E1E24] ${i % 2 === 0 ? 'bg-[#0D0D0F]' : 'bg-[#141417]'}`}>
                  <td class="px-5 py-4 font-medium text-[#F0F0F2]">{row.aspect}</td>
                  <td class="px-5 py-4 text-[#8888A0]">{row.td1}</td>
                  <td class="px-5 py-4 text-[#B0B0BE]">
                    <span class="text-[#22C55E] font-medium">{row.td2}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-20 border-t border-[#2A2A33]">
    <div class="container">
