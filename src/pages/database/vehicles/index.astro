---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = 'Turbo Dismount 2 Vehicles — Stats & Ratings';
const description = 'All Turbo Dismount 2 vehicles with speed, handling, durability stats. Compare 12+ cars, trucks, and special vehicles side-by-side. Find the best vehicle for every game mode and high scores.';

interface Vehicle {
  name: string;
  type: string;
  category: 'Cars' | 'Trucks' | 'Special Vehicles';
  speed: number;
  handling: number;
  durability: number;
  specialAbility: string;
  recommendedFor: string;
  badge?: string;
  badgeColor?: string;
  note?: string;
}

const vehicles: Vehicle[] = [
  {
    name: 'Corley',
    type: 'Standard Sedan',
    category: 'Cars',
    speed: 5,
    handling: 7,
    durability: 5,
    specialAbility: 'Balanced all-rounder, predictable behavior',
    recommendedFor: 'Learning the game, general play',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Pink Lightning',
    type: 'Sports Car',
    category: 'Cars',
    speed: 8,
    handling: 5,
    durability: 3,
    specialAbility: 'High-speed launch, quick acceleration',
    recommendedFor: 'Distance records, high-speed crashes',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Golf R',
    type: 'Sport Compact',
    category: 'Cars',
    speed: 7,
    handling: 8,
    durability: 5,
    specialAbility: 'Excellent cornering and stability',
    recommendedFor: 'Technical levels, precision driving',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Ranger',
    type: 'Jeep / SUV',
    category: 'Trucks',
    speed: 5,
    handling: 7,
    durability: 8,
    specialAbility: 'Off-road capable, survives heavy impacts',
    recommendedFor: 'Beginners, obstacle courses',
    badge: 'Beginner Pick',
    badgeColor: '#22C55E',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Wedge',
    type: 'Wedge Racer',
    category: 'Cars',
    speed: 10,
    handling: 2,
    durability: 2,
    specialAbility: 'Maximum velocity, aerodynamic body',
    recommendedFor: 'Max distance runs, open highways',
    badge: 'Max Speed',
    badgeColor: '#F57200',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Sasquatch',
    type: 'Monster Truck',
    category: 'Trucks',
    speed: 3,
    handling: 2,
    durability: 10,
    specialAbility: 'Crushes everything, near-indestructible',
    recommendedFor: 'Survival runs, rampage modes',
    badge: 'Max Durability',
    badgeColor: '#EAB308',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Street Slicer',
    type: 'Skateboard',
    category: 'Special Vehicles',
    speed: 5,
    handling: 6,
    durability: 1,
    specialAbility: 'Low profile, unique physics behavior',
    recommendedFor: 'Challenge runs, trick scores',
    badge: 'Unique',
    badgeColor: '#0080F5',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
  {
    name: 'Token Bird',
    type: 'Bird Vehicle',
    category: 'Special Vehicles',
    speed: 7,
    handling: 4,
    durability: 2,
    specialAbility: 'Gliding ability, airborne maneuvers',
    recommendedFor: 'Aerial challenges, creative runs',
    badge: 'Unique',
    badgeColor: '#0080F5',
    note: 'Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.',
  },
];

const categories = ['Cars', 'Trucks', 'Special Vehicles'] as const;

const bestFor = [
  { mode: 'High Score Runs', vehicle: 'Wedge', reason: 'Maximum speed for massive collision energy' },
  { mode: 'Distance Records', vehicle: 'Pink Lightning', reason: 'Fast launch + aerodynamic body for long slides' },
  { mode: 'Obstacle Courses', vehicle: 'Ranger', reason: 'High durability survives multiple hits' },
  { mode: 'Beginners', vehicle: 'Ranger', reason: 'Forgiving handling and tough construction' },
  { mode: 'Survival Mode', vehicle: 'Sasquatch', reason: 'Near-indestructible, outlasts every obstacle' },
  { mode: 'Technical Tracks', vehicle: 'Golf R', reason: 'Best handling for precise navigation' },
  { mode: 'Creative Challenges', vehicle: 'Street Slicer', reason: 'Unique physics enable special trick opportunities' },
  { mode: 'Aerial Levels', vehicle: 'Token Bird', reason: 'Gliding helps control trajectory mid-air' },
];

const faqs = [
  {
    q: 'How many vehicles are in Turbo Dismount 2?',
    a: 'Turbo Dismount 2 includes at least 8 confirmed vehicle types across Cars, Trucks, and Special Vehicles categories. The Steam Workshop also allows community creators to add custom vehicles.',
  },
  {
    q: 'Which vehicle is best for beginners?',
    a: 'The Ranger (Jeep/SUV) is the top pick for beginners. Its high durability (8/10) and good handling (7/10) make it forgiving to drive, and you can survive crashes that would destroy lighter vehicles.',
  },
  {
    q: 'What is the fastest vehicle in Turbo Dismount 2?',
    a: 'The Wedge has the highest speed rating (10/10), making it the fastest vehicle in the game. However, it has very poor handling (2/10) and low durability (2/10), so it\'s best suited for open, straight-line courses.',
  },
  {
    q: 'Can I unlock new vehicles in the Workshop?',
    a: 'Yes. The Steam Workshop allows creators to build and share custom vehicles using the same developer-grade tools. You can subscribe to Workshop content to add new vehicles to your game.',
  },
  {
    q: 'Do vehicle stats affect score calculation?',
    a: 'Vehicle speed directly impacts collision energy, which affects damage scoring. Heavier vehicles like the Sasquatch deliver more impact force. The optimal vehicle depends on your scoring strategy and the specific level layout.',
  },
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Turbo Dismount 2 Vehicle Database',
  description: 'Complete list of all vehicles in Turbo Dismount 2 with stats and ratings',
  numberOfItems: vehicles.length,
  itemListElement: vehicles.map((v, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: v.name,
    description: `${v.type} — Speed: ${v.speed}/10, Handling: ${v.handling}/10, Durability: ${v.durability}/10. ${v.recommendedFor}`,
  })),
};
---

<BaseLayout title={title} description={description} ogImage="/og-vehicles.png">
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://turbodismount2.com/" },
      { "@type": "ListItem", "position": 2, "name": "Vehicle Database", "item": "https://turbodismount2.com/database/vehicles/" }
    ]
  })} />

  <!-- ItemList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A0A00 0%, #2D1200 40%, #0D1A2E 80%, #080D18 100%);"></div>
    <img src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/header.jpg?t=1773497496" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-15 pointer-events-none select-none" loading="eager" width="460" height="215" />
    <div class="absolute top-1/2 left-1/4 w-[600px] h-[300px] opacity-15" style="background: radial-gradient(ellipse, rgba(245,114,0,0.4) 0%, transparent 70%);"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#8888A0] mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF8C12] transition-colors">Home</a>
        <span>/</span>
        <a href="/database/" class="hover:text-[#FF8C12] transition-colors">Database</a>
        <span>/</span>
        <span class="text-[#B0B0BE]">Vehicles</span>
      </nav>

      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-5 text-xs font-semibold uppercase tracking-wider rounded-full border border-[rgba(245,114,0,0.3)] bg-[rgba(245,114,0,0.08)] text-[#FF8C12]">
          <span class="w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          {vehicles.length} Vehicles Documented
        </div>

        <h1 class="font-[Orbitron] font-black text-3xl md:text-5xl uppercase tracking-wider leading-tight mb-5">
          <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
            Turbo Dismount 2
          </span>
          <br />
          <span class="text-[#F0F0F2]">Vehicle Database</span>
        </h1>

        <p class="text-base md:text-lg text-[#B0B0BE] leading-relaxed max-w-2xl">
          Complete stats for all {vehicles.length} vehicles — speed, handling, and durability ratings with recommended game modes.
          Find the right vehicle for every situation.
        </p>

        <p class="text-xs text-[#8888A0] mt-4 italic">
          Community-estimated relative stats — not official game values. Ratings are comparative 1-10 scales.
        </p>

        <img src="https://cdn.cloudflare.steamstatic.com/steam/apps/2280350/capsule_616x353.jpg" alt="Turbo Dismount 2 vehicles and destruction physics" class="mt-6 rounded-xl border border-[#2A2A33] w-full max-w-lg mx-auto" loading="lazy" width="616" height="353" />
      </div>
    </div>
  </section>

  <!-- Quick Stats Summary -->
  <section class="border-t border-[#2A2A33] bg-[#141417]">
    <div class="container py-6">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <div class="font-[Orbitron] font-bold text-xl text-[#F57200]">{vehicles.length}</div>
          <div class="text-xs text-[#8888A0] uppercase tracking-wider mt-1">Total Vehicles</div>
        </div>
        <div>
          <div class="font-[Orbitron] font-bold text-xl text-[#0080F5]">{categories.length}</div>
          <div class="text-xs text-[#8888A0] uppercase tracking-wider mt-1">Categories</div>
        </div>
        <div>
          <div class="font-[Orbitron] font-bold text-xl text-[#22C55E]">3</div>
          <div class="text-xs text-[#8888A0] uppercase tracking-wider mt-1">Stat Dimensions</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Compare Tool (CSS-only, no JS) -->
  <section class="py-8 border-t border-[#2A2A33]">
    <div class="container">
      <details class="group max-w-4xl mx-auto">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-3 rounded-xl border border-[#2A2A33] bg-[#141417] hover:bg-[#1E1E24] transition-colors duration-200">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#F57200]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            <span class="font-bold text-sm text-[#F0F0F2]">Quick Compare — All Vehicles at a Glance</span>
          </div>
          <svg class="w-5 h-5 text-[#8888A0] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-3 overflow-x-auto rounded-xl border border-[#2A2A33] table-scroll-wrapper">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-[#1E1E24]">
                <th class="text-left px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold">Vehicle</th>
                <th class="text-left px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold">Type</th>
                <th class="text-center px-4 py-3 text-[#F57200] text-xs uppercase tracking-wider font-semibold">Speed</th>
                <th class="text-center px-4 py-3 text-[#0080F5] text-xs uppercase tracking-wider font-semibold">Handling</th>
                <th class="text-center px-4 py-3 text-[#22C55E] text-xs uppercase tracking-wider font-semibold">Durability</th>
                <th class="text-left px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold">Best For</th>
              </tr>
            </thead>
            <tbody>
              {vehicles.map((v, i) => (
                <tr class={`border-t border-[#1E1E24] ${i % 2 === 0 ? 'bg-[#141417]' : 'bg-[rgba(255,255,255,0.02)]'}`}>
                  <td class="px-4 py-2.5 font-medium text-[#F0F0F2]">{v.name}</td>
                  <td class="px-4 py-2.5 text-[#8888A0] text-xs">{v.category}</td>
                  <td class="text-center px-4 py-2.5 font-bold text-[#F57200]">{v.speed}</td>
                  <td class="text-center px-4 py-2.5 font-bold text-[#0080F5]">{v.handling}</td>
                  <td class="text-center px-4 py-2.5 font-bold text-[#22C55E]">{v.durability}</td>
                  <td class="px-4 py-2.5 text-[#8888A0] text-xs">{v.recommendedFor}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-[#8888A0] mt-2 italic px-1">Community-estimated ratings. Click column headers to compare. Expand individual cards below for full details.</p>
      </details>
    </div>
  </section>

  <!-- Vehicle Cards by Category -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">

      {categories.map((cat) => {
        const catVehicles = vehicles.filter(v => v.category === cat);
        const catColors = {
          'Cars': '#0080F5',
          'Trucks': '#EAB308',
          'Special Vehicles': '#A855F7',
        };
        const color = catColors[cat];
        return (
          <div class="mb-16">
            <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-2 flex items-center gap-3">
              <span class="w-1 h-7 rounded-full" style={`background: ${color};`}></span>
              {cat}
              <span class="text-sm font-normal text-[#8888A0]">({catVehicles.length} vehicles)</span>
            </h2>
            <p class="text-sm text-[#8888A0] mb-8 ml-4">
              {cat === 'Cars' && 'Standard road vehicles ranging from sedans to high-performance racers.'}
              {cat === 'Trucks' && 'Heavy-duty vehicles built for durability and raw impact force.'}
              {cat === 'Special Vehicles' && 'Unique non-standard vehicles with distinctive physics and abilities.'}
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {catVehicles.map((v) => (
                <div class="relative p-6 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-300 hover:-translate-y-1 group">
                  {v.badge && (
                    <span
                      class="absolute top-4 right-4 px-2 py-0.5 rounded-md text-xs font-bold uppercase tracking-wider"
                      style={`background: ${v.badgeColor}22; color: ${v.badgeColor}; border: 1px solid ${v.badgeColor}44;`}
                    >
                      {v.badge}
                    </span>
                  )}

                  <!-- Vehicle Name & Type -->
                  <div class="mb-5">
                    <h3 class="font-[Orbitron] text-lg font-bold text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors duration-200 uppercase tracking-wide pr-24">
                      {v.name}
                    </h3>
                    <p class="text-xs text-[#8888A0] mt-0.5 uppercase tracking-wider">{v.type}</p>
                  </div>

                  <!-- Stat Bars -->
                  <div class="space-y-3 mb-5">
                    <!-- Speed -->
                    <div>
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-semibold text-[#B0B0BE] uppercase tracking-wider">Speed</span>
                        <span class="text-xs font-bold text-[#F57200]">{v.speed}/10</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-[#2A2A33] overflow-hidden">
                        <div
                          class="h-full rounded-full transition-all duration-500"
                          style={`width: ${v.speed * 10}%; background: linear-gradient(90deg, #F57200, #FF8C12);`}
                        ></div>
                      </div>
                    </div>

                    <!-- Handling -->
                    <div>
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-semibold text-[#B0B0BE] uppercase tracking-wider">Handling</span>
                        <span class="text-xs font-bold text-[#0080F5]">{v.handling}/10</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-[#2A2A33] overflow-hidden">
                        <div
                          class="h-full rounded-full transition-all duration-500"
                          style={`width: ${v.handling * 10}%; background: linear-gradient(90deg, #0080F5, #2E9EFF);`}
                        ></div>
                      </div>
                    </div>

                    <!-- Durability -->
                    <div>
                      <div class="flex justify-between items-center mb-1">
                        <span class="text-xs font-semibold text-[#B0B0BE] uppercase tracking-wider">Durability</span>
                        <span class="text-xs font-bold text-[#22C55E]">{v.durability}/10</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-[#2A2A33] overflow-hidden">
                        <div
                          class="h-full rounded-full transition-all duration-500"
                          style={`width: ${v.durability * 10}%; background: linear-gradient(90deg, #22C55E, #4ADE80);`}
                        ></div>
                      </div>
                    </div>
                  </div>

                  <!-- Special Ability -->
                  <div class="mb-3 pb-3 border-b border-[#2A2A33]">
                    <p class="text-xs text-[#8888A0] uppercase tracking-wider mb-1">Special Ability</p>
                    <p class="text-sm text-[#B0B0BE]">{v.specialAbility}</p>
                  </div>

                  <!-- Recommended For -->
                  <div>
                    <p class="text-xs text-[#8888A0] uppercase tracking-wider mb-1">Best For</p>
                    <p class="text-sm text-[#B0B0BE]">{v.recommendedFor}</p>
                  </div>

                  {v.note && (
                    <p class="text-xs text-[#8888A0] italic mt-3 pt-3 border-t border-[#1E1E24]">
                      Source: {v.note}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Best Vehicles for Each Game Mode -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-3">
          Best Vehicles for Each Game Mode
        </h2>
        <p class="text-[#B0B0BE] mb-10 text-sm">
          Quick reference guide — match your vehicle to your goal for the best results.
          See the <a href="/database/levels/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">Level Database</a> for per-level strategies,
          or the <a href="/guides/how-to-play/" class="text-[#FF8C12] hover:text-[#FFAA44] font-medium">How to Play</a> guide for physics fundamentals.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {bestFor.map((item) => (
            <div class="flex items-start gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.2)] transition-colors duration-200">
              <div class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center text-sm font-bold font-[Orbitron] text-[#F57200]" style="background: rgba(245,114,0,0.1);">
                {item.vehicle.slice(0, 2).toUpperCase()}
              </div>
              <div>
                <p class="text-xs text-[#8888A0] uppercase tracking-wider mb-0.5">{item.mode}</p>
                <p class="text-sm font-bold text-[#F0F0F2]">{item.vehicle}</p>
                <p class="text-xs text-[#B0B0BE] mt-1">{item.reason}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Tips for Vehicle Selection -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider mb-8">
          Tips for Vehicle Selection
        </h2>

        <div class="space-y-4">
          {[
            {
              title: 'Match Vehicle to Level Layout',
              tip: 'Open highways favor high-speed vehicles like the Wedge or Pink Lightning. Tight obstacle courses reward the handling of the Golf R. Dense crash zones benefit from the Sasquatch\'s durability.',
            },
            {
              title: 'Speed = Collision Energy',
              tip: 'Higher speed at impact generates more damage and higher scores. The Wedge reaches maximum velocity quickly, making it optimal for pure damage runs on open maps.',
            },
            {
              title: 'Durability for Exploration',
              tip: 'If you\'re learning a new level, start with the Ranger or Sasquatch. Their high durability lets you explore the full level layout before optimizing your run.',
            },
            {
              title: 'Special Vehicles Need Adaptation',
              tip: 'Street Slicer and Token Bird have unique physics that require practice. They can achieve scores impossible with standard vehicles once you understand their mechanics.',
            },
            {
              title: 'Workshop Expands Your Options',
              tip: 'The Steam Workshop adds community-created vehicles beyond the default roster. Check Workshop content for vehicles with stats tuned specifically for certain level types.',
            },
          ].map((tip, i) => (
            <div class="flex gap-4 p-5 rounded-xl border border-[#2A2A33] bg-[#141417]">
              <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold font-[Orbitron] text-white" style="background: linear-gradient(135deg, #F57200, #C95A00);">
                {i + 1}
              </div>
              <div>
                <p class="font-semibold text-[#F0F0F2] mb-1">{tip.title}</p>
                <p class="text-sm text-[#B0B0BE] leading-relaxed">{tip.tip}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider text-center mb-10">
          Vehicle FAQ
        </h2>

        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="group rounded-xl border border-[#2A2A33] bg-[#141417] overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-[#F0F0F2] font-medium hover:bg-[#1E1E24] transition-colors duration-200">
                <span>{faq.q}</span>
                <svg class="w-5 h-5 text-[#8888A0] shrink-0 ml-4 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm text-[#B0B0BE] leading-relaxed border-t border-[#1E1E24]">
                <p class="pt-4">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

