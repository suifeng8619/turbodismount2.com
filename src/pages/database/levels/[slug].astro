---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { officialLevels, difficultyColors } from '../../../data/levels';
import { vehicles } from '../../../data/vehicles';
import { GAME } from '../../../data/constants';

export function getStaticPaths() {
  return officialLevels.map((l, i) => ({
    params: { slug: l.slug },
    props: {
      level: l,
      index: i,
      prev: i > 0 ? officialLevels[i - 1] : null,
      next: i < officialLevels.length - 1 ? officialLevels[i + 1] : null,
    },
  }));
}

const { level, index, prev, next } = Astro.props;

const seoTitle = `${level.name} — Turbo Dismount 2 Level Guide & Strategy`;
const seoDescription = `Turbo Dismount 2 ${level.name} level walkthrough. Difficulty: ${level.difficulty}/5. Theme: ${level.theme}. High score tips and best vehicle recommendations.`;
const canonicalUrl = `https://turbodismount2.com/database/levels/${level.slug}/`;

const starColor = difficultyColors[level.difficulty];

const bestVehicleData = level.bestVehicles
  .map(bv => {
    const v = vehicles.find(vehicle => vehicle.slug === bv.slug);
    return v ? { ...v, reason: bv.reason } : null;
  })
  .filter(Boolean);

const hasExtendedContent = level.extendedGuide.length > 0;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: seoTitle,
  description: seoDescription,
  image: 'https://turbodismount2.com/og-levels.png',
  author: { '@type': 'Organization', name: 'turbodismount2.com' },
  publisher: { '@type': 'Organization', name: 'turbodismount2.com' },
  datePublished: '2026-03-21',
  dateModified: '2026-03-21',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://turbodismount2.com/' },
    { '@type': 'ListItem', position: 2, name: 'Levels', item: 'https://turbodismount2.com/database/levels/' },
    { '@type': 'ListItem', position: 3, name: level.name, item: canonicalUrl },
  ],
};

const faqSchema = level.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: level.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const highScoreSteps = level.highScoreTip.split(/[.!]\s+/).filter(s => s.trim().length > 0).map(s => s.endsWith('.') ? s : s + '.');
---

<BaseLayout title={seoTitle} description={seoDescription} ogImage="/og-levels.png" canonicalUrl={canonicalUrl} type="article">
  <!-- Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <!-- BreadcrumbList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <!-- FAQPage Schema -->
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1A0A00 0%, #2D1200 40%, #0D0D0F 80%, #080D18 100%);"></div>
    <img src="https://img.youtube.com/vi/_eY5eaJG-1s/maxresdefault.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-10 pointer-events-none select-none" loading="eager" width="1280" height="720" />
    <div class="absolute top-1/2 left-1/4 w-[600px] h-[300px] opacity-15" style="background: radial-gradient(ellipse, rgba(245,114,0,0.4) 0%, transparent 70%);"></div>

    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[#8888A0] mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF8C12] transition-colors">Home</a>
        <span>/</span>
        <a href="/database/" class="hover:text-[#FF8C12] transition-colors">Database</a>
        <span>/</span>
        <a href="/database/levels/" class="hover:text-[#FF8C12] transition-colors">Levels</a>
        <span>/</span>
        <span class="text-[#B0B0BE]">{level.name}</span>
      </nav>

      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {level.badge && (
            <span
              class="inline-block px-3 py-1 rounded-md text-xs font-bold uppercase tracking-wider"
              style={`background: ${level.badgeColor}22; color: ${level.badgeColor}; border: 1px solid ${level.badgeColor}44;`}
            >
              {level.badge}
            </span>
          )}

          <!-- Difficulty Stars -->
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5" aria-label={`Difficulty ${level.difficulty} out of 5`}>
              {Array.from({ length: 5 }, (_, i) => (
                <svg class="w-4 h-4" viewBox="0 0 20 20" fill={i < level.difficulty ? starColor : '#2A2A33'} aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-xs text-[#8888A0]">{level.difficulty}/5</span>
          </div>
        </div>

        <h1 class="font-[Orbitron] font-black text-3xl md:text-5xl uppercase tracking-wider leading-tight mb-4">
          <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent">
            Turbo Dismount 2
          </span>
          <br />
          <span class="text-[#F0F0F2]">{level.name}</span>
        </h1>

        <p class="text-base md:text-lg text-[#B0B0BE]">
          {level.theme} — {level.type}
        </p>
      </div>
    </div>
  </section>

  <!-- Level Overview -->
  <section class="py-10 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
          <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
          Level Overview
        </h2>

        <p class="text-sm text-[#B0B0BE] leading-relaxed mb-6">{level.description}</p>

        {hasExtendedContent && (
          <div class="mb-6">
            {level.extendedGuide.split('\n\n').map(paragraph => (
              <p class="text-sm text-[#B0B0BE] leading-relaxed mb-4">{paragraph}</p>
            ))}
          </div>
        )}

        <!-- Info Table -->
        <div class="overflow-hidden rounded-xl border border-[#2A2A33]">
          <table class="w-full text-sm">
            <tbody>
              <tr class="bg-[#141417] border-b border-[#1E1E24]">
                <td class="px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold w-1/3">Theme</td>
                <td class="px-4 py-3 text-[#F0F0F2]">{level.theme}</td>
              </tr>
              <tr class="bg-[#0D0D0F] border-b border-[#1E1E24]">
                <td class="px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold">Type</td>
                <td class="px-4 py-3 text-[#F0F0F2]">{level.type}</td>
              </tr>
              <tr class="bg-[#141417]">
                <td class="px-4 py-3 text-[#8888A0] text-xs uppercase tracking-wider font-semibold">Difficulty</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <div class="flex gap-0.5">
                      {Array.from({ length: 5 }, (_, i) => (
                        <svg class="w-4 h-4" viewBox="0 0 20 20" fill={i < level.difficulty ? starColor : '#2A2A33'} aria-hidden="true">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                    </div>
                    <span class="text-[#F0F0F2] font-bold">{level.difficulty}/5</span>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="text-xs text-[#8888A0] mt-3 italic">
          Difficulty is a community-based assessment — not an official in-game rating.
        </p>
      </div>
    </div>
  </section>

  <!-- High Score Strategy -->
  <section class="py-10 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
          <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
          High Score Strategy
        </h2>

        <div class="space-y-3">
          {highScoreSteps.map((step, i) => (
            <div class="flex gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
              <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold font-[Orbitron] text-white" style="background: linear-gradient(135deg, #F57200, #C95A00);">
                {i + 1}
              </div>
              <p class="text-sm text-[#B0B0BE] leading-relaxed">{step}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Best Vehicles -->
  {bestVehicleData.length > 0 && (
    <section class="py-10 border-t border-[#2A2A33]">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
            Best Vehicles for {level.name}
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {bestVehicleData.map(v => v && (
              <a
                href={`/database/vehicles/${v.slug}/`}
                class="p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200 block group"
              >
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="font-bold text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors">{v.name}</h3>
                  {v.badge && (
                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold uppercase" style={`background: ${v.badgeColor}22; color: ${v.badgeColor};`}>
                      {v.badge}
                    </span>
                  )}
                </div>
                <p class="text-xs text-[#8888A0] mb-2">{v.type} — {v.category}</p>
                <div class="flex gap-3 text-xs mb-3">
                  <span class="text-[#F57200]">Spd {v.speed}</span>
                  <span class="text-[#EAB308]">Hdl {v.handling}</span>
                  <span class="text-[#22C55E]">Dur {v.durability}</span>
                </div>
                <p class="text-xs text-[#B0B0BE] leading-relaxed">{v.reason}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Tips & Tricks -->
  {level.tips.length > 0 && (
    <section class="py-10 border-t border-[#2A2A33]">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
            Tips & Tricks
          </h2>

          <div class="space-y-3">
            {level.tips.map((tip, i) => (
              <div class="flex gap-4 p-4 rounded-xl border border-[#2A2A33] bg-[#141417]">
                <div class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold font-[Orbitron] text-white" style="background: linear-gradient(135deg, #F57200, #C95A00);">
                  {i + 1}
                </div>
                <p class="text-sm text-[#B0B0BE] leading-relaxed">{tip}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {level.faqs.length > 0 && (
    <section class="py-10 border-t border-[#2A2A33]">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
            <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
            {level.name} FAQ
          </h2>

          <div class="space-y-3">
            {level.faqs.map(faq => (
              <details class="group rounded-xl border border-[#2A2A33] bg-[#141417] overflow-hidden">
                <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-[#F0F0F2] font-medium hover:bg-[#1E1E24] transition-colors duration-200">
                  <span>{faq.q}</span>
                  <svg class="w-5 h-5 text-[#8888A0] shrink-0 ml-4 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-sm text-[#B0B0BE] leading-relaxed border-t border-[#1E1E24]">
                  <p class="pt-4">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Video Section -->
  <section class="py-10 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-[Orbitron] text-lg md:text-xl font-bold uppercase tracking-wider mb-6 flex items-center gap-3">
          <span class="w-1 h-6 rounded-full bg-[#F57200]"></span>
          See {level.name} in Action
        </h2>

        <div class="relative rounded-xl overflow-hidden border border-[#2A2A33] bg-[#141417]" style="aspect-ratio: 16/9;">
          <iframe
            id={`trailer-${level.slug}`}
            class="absolute inset-0 w-full h-full hidden"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
          <button
            id={`trailer-btn-${level.slug}`}
            class="absolute inset-0 w-full h-full flex flex-col items-center justify-center cursor-pointer group z-10"
            style="background: linear-gradient(180deg, rgba(13,13,15,0.3) 0%, rgba(13,13,15,0.7) 100%);"
            aria-label={`Play Turbo Dismount 2 ${level.name} gameplay trailer`}
          >
            <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center transition-all duration-300 group-hover:scale-110" style="background: rgba(245,114,0,0.9); box-shadow: 0 0 32px rgba(245,114,0,0.5);">
              <svg class="w-7 h-7 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <span class="mt-4 text-sm font-medium text-[#B0B0BE] group-hover:text-white transition-colors duration-200">Watch Gameplay Trailer</span>
          </button>
          <img
            src="https://img.youtube.com/vi/_eY5eaJG-1s/maxresdefault.jpg"
            alt={`Turbo Dismount 2 ${level.name} gameplay trailer thumbnail`}
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            width="1280"
            height="720"
          />
        </div>

        <p class="text-xs text-[#8888A0] mt-3 italic">
          Turbo Dismount 2 official gameplay trailer.
        </p>
      </div>
    </div>
  </section>

  <!-- Navigation: Prev / All / Next -->
  <section class="py-10 border-t border-[#2A2A33]">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-stretch justify-between gap-3">
          <!-- Previous -->
          <div class="flex-1">
            {prev && (
              <a href={`/database/levels/${prev.slug}/`} class="flex flex-col p-4 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200 h-full">
                <span class="text-xs text-[#8888A0] mb-1">&larr; Previous</span>
                <span class="text-sm font-bold text-[#F0F0F2]">{prev.name}</span>
                <span class="text-xs text-[#8888A0]">{prev.theme}</span>
              </a>
            )}
          </div>

          <!-- All Levels -->
          <div class="flex items-center">
            <a href="/database/levels/" class="px-5 py-3 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200 text-sm font-semibold text-[#F0F0F2] whitespace-nowrap">
              All Levels
            </a>
          </div>

          <!-- Next -->
          <div class="flex-1">
            {next && (
              <a href={`/database/levels/${next.slug}/`} class="flex flex-col items-end p-4 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-200 h-full text-right">
                <span class="text-xs text-[#8888A0] mb-1">Next &rarr;</span>
                <span class="text-sm font-bold text-[#F0F0F2]">{next.name}</span>
                <span class="text-xs text-[#8888A0]">{next.theme}</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-[#B0B0BE] mb-4 text-sm">
          All official levels plus unlimited Workshop content with one purchase.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href={GAME.steamUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-bold text-white rounded-xl transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #FF8C12 0%, #F57200 50%, #C95A00 100%); box-shadow: 0 4px 20px rgba(245,114,0,0.35);"
          >
            Get on Steam — {GAME.price}
          </a>
          <a
            href="/guides/how-to-play/"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold text-[#F0F0F2] rounded-xl border border-[#2A2A33] hover:border-[rgba(245,114,0,0.4)] bg-[#141417] hover:bg-[#1E1E24] transition-all duration-300"
          >
            How to Play
            <svg class="w-4 h-4 text-[#F57200]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Lite YouTube loader -->
  <script define:vars={{ slug: level.slug }}>
    document.getElementById(`trailer-btn-${slug}`)?.addEventListener('click', () => {
      const iframe = document.getElementById(`trailer-${slug}`);
      const btn = document.getElementById(`trailer-btn-${slug}`);
      if (iframe && btn) {
        iframe.src = 'https://www.youtube-nocookie.com/embed/_eY5eaJG-1s?autoplay=1&rel=0';
        iframe.classList.remove('hidden');
        btn.classList.add('hidden');
      }
    });
  </script>
</BaseLayout>
