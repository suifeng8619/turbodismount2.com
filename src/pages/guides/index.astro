---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Turbo Dismount 2 Guides — How to Play, Tips & Strategies';
const description = 'All Turbo Dismount 2 guides. Learn how to play, master scoring, vehicle selection, and advanced techniques.';

const guides = [
  {
    href: '/guides/how-to-play/',
    title: 'How to Play',
    subtitle: 'Complete Beginner\'s Guide',
    description: 'Everything you need to start playing Turbo Dismount 2 — controls, all 6 game modes, vehicle physics, the scoring system, replay tools, and Steam Workshop basics.',
    tags: ['Controls', 'Game Modes', 'Scoring', 'Workshop'],
    tagColor: '#0080F5',
    accent: '#0080F5',
  },
  {
    href: '/guides/tips/',
    title: 'Tips & Tricks',
    subtitle: '15 Pro Strategies',
    description: 'Advanced strategies for scoring higher and crashing smarter. Vehicle selection for each mode, launch angle optimization, power bar timing, score multipliers, and character pose techniques.',
    tags: ['Vehicle Selection', 'Launch Angles', 'Score Multipliers', 'Advanced'],
    tagColor: '#22C55E',
    accent: '#22C55E',
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://turbodismount2.com/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://turbodismount2.com/guides/" },
  ]
};
---

<BaseLayout title={title} description={description}>

  <!-- Page Header -->
  <section class="relative py-12 md:py-16 border-b border-[#2A2A33] overflow-hidden">
    <img
      src="https://shared.st.dl.eccdnx.com/store_item_assets/steam/apps/2280350/page_bg_raw.jpg?t=1773497496"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-[0.08]"
      loading="eager"
      aria-hidden="true"
    />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, #0D001A 0%, #0D0D0F 100%);"></div>
    <div class="container relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-[#8888A0] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#FF8C12] transition-colors duration-200">Home</a>
        <span>/</span>
        <span class="text-[#B0B0BE]">Guides</span>
      </nav>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-[rgba(0,128,245,0.12)] text-[#0080F5] border border-[rgba(0,128,245,0.25)]">
          {guides.length} Guides
        </span>
        <span class="text-sm text-[#8888A0]">Updated: <time datetime="2026-03">March 2026</time></span>
      </div>

      <h1 class="font-[Orbitron] font-black text-3xl md:text-4xl lg:text-5xl uppercase tracking-wider leading-tight mb-4">
        Turbo Dismount 2
        <span class="bg-gradient-to-r from-[#FFAA44] via-[#FF8C12] to-[#F57200] bg-clip-text text-transparent block mt-1">
          Guides
        </span>
      </h1>
      <p class="max-w-2xl text-[#B0B0BE] text-base md:text-lg leading-relaxed">
        Learn how to play Turbo Dismount 2, master every game mode, optimize your vehicle selection, and maximize your score with advanced techniques.
      </p>
    </div>
  </section>

  <!-- Guide Cards -->
  <section class="py-12 md:py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto space-y-6">

        {guides.map((guide) => (
          <a
            href={guide.href}
            class="group block rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] hover:bg-[#1E1E24] transition-all duration-300 hover:-translate-y-1 overflow-hidden"
          >
            <div class="p-6 md:p-8">
              <!-- Title row -->
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider text-[#F0F0F2] group-hover:text-[#FF8C12] transition-colors duration-200">
                    {guide.title}
                  </h2>
                  <p class="text-sm font-semibold mt-1" style={`color: ${guide.accent};`}>
                    {guide.subtitle}
                  </p>
                </div>
                <svg class="w-6 h-6 text-[#8888A0] group-hover:text-[#F57200] shrink-0 mt-1 transition-all duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>

              <!-- Description -->
              <p class="text-sm text-[#B0B0BE] leading-relaxed mb-4">
                {guide.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {guide.tags.map((tag) => (
                  <span
                    class="px-2.5 py-1 rounded-md text-xs font-medium"
                    style={`background: ${guide.tagColor}15; color: ${guide.tagColor}; border: 1px solid ${guide.tagColor}30;`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}

      </div>
    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-12 md:py-16 border-t border-[#2A2A33]">
    <div class="container">
      <h2 class="font-[Orbitron] text-xl md:text-2xl font-bold uppercase tracking-wider text-center mb-8">Related Resources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
        <a href="/database/vehicles/" class="group p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] transition-all duration-300">
          <h3 class="font-bold text-[#F0F0F2] mb-1 group-hover:text-[#FF8C12]">Vehicle Database</h3>
          <p class="text-sm text-[#8888A0]">Stats, speed, handling for every vehicle</p>
        </a>
        <a href="/database/levels/" class="group p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] transition-all duration-300">
          <h3 class="font-bold text-[#F0F0F2] mb-1 group-hover:text-[#FF8C12]">Level Database</h3>
          <p class="text-sm text-[#8888A0]">Maps, walkthroughs, and high score tips</p>
        </a>
        <a href="/faq/" class="group p-5 rounded-xl border border-[#2A2A33] bg-[#141417] hover:border-[rgba(245,114,0,0.3)] transition-all duration-300">
          <h3 class="font-bold text-[#F0F0F2] mb-1 group-hover:text-[#FF8C12]">FAQ</h3>
          <p class="text-sm text-[#8888A0]">25+ common questions answered</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
