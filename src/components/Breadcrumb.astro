---
interface Props {
  items: { label: string; href?: string }[];
}
const { items } = Astro.props;
const siteUrl = 'https://turbodismount2.com';
---

<nav class="flex items-center gap-2 text-xs text-[#8888A0] mb-8" aria-label="Breadcrumb">
  <ol class="flex items-center gap-2">
    <li>
      <a href="/" class="hover:text-[#FF8C12] transition-colors duration-200">Home</a>
    </li>
    {items.map((item, i) => (
      <>
        <li aria-hidden="true"><span>/</span></li>
        <li>
          {item.href ? (
            <a href={item.href} class="hover:text-[#FF8C12] transition-colors duration-200">{item.label}</a>
          ) : (
            <span class="text-[#B0B0BE]">{item.label}</span>
          )}
        </li>
      </>
    ))}
  </ol>
</nav>

<!-- BreadcrumbList Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl + "/" },
    ...items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": item.label,
      ...(item.href ? { "item": siteUrl + item.href } : {}),
    })),
  ],
})} />
